#!/bin/sh

fail_startup() {
  printf '%s\n' '{"code":"unsafe_startup_environment","message":"unsafe inherited startup state rejected"}' >&2
  exit 1
}

for name in \
  NODE_OPTIONS NODE_PATH \
  GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE GIT_OBJECT_DIRECTORY \
  GIT_ALTERNATE_OBJECT_DIRECTORIES GIT_COMMON_DIR GIT_NAMESPACE \
  GIT_REPLACE_REF_BASE GIT_CONFIG_COUNT GIT_CONFIG_SYSTEM GIT_CONFIG_GLOBAL
do
  eval "is_set=\${$name+x}"
  [ "$is_set" = x ] && fail_startup
done

case $0 in
  /*) launcher=$0 ;;
  *) launcher=$PWD/$0 ;;
esac
script_dir=${launcher%/*}
repository_root=${script_dir%/tools/oracle-lab}
repository_root=$(cd -P "$repository_root" 2>/dev/null && pwd -P) || fail_startup

select_tool() {
  for candidate in "$@"; do
    if [ -x "$candidate" ] && [ ! -d "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

node_executable=$(select_tool /opt/homebrew/bin/node /usr/local/bin/node /usr/bin/node) || fail_startup
git_executable=$(select_tool /opt/homebrew/bin/git /usr/local/bin/git /usr/bin/git) || fail_startup
codegraph_executable=$(select_tool /opt/homebrew/bin/codegraph /usr/local/bin/codegraph) || fail_startup
tsx_cli=$repository_root/node_modules/tsx/dist/cli.mjs
typescript_entry=$repository_root/tools/oracle-lab/governance-amendment-evidence.ts
[ -f "$tsx_cli" ] && [ ! -L "$typescript_entry" ] && [ -f "$typescript_entry" ] || fail_startup

parent_path=${PATH-/usr/bin:/bin}
parent_home=${HOME-/tmp}
parent_tmp=${TMPDIR-/tmp}

old_ifs=$IFS
IFS=:
for directory in $parent_path; do
  [ -n "$directory" ] || directory=.
  for tool in node git codegraph tsx; do
    candidate=$directory/$tool
    [ -e "$candidate" ] || continue
    case $candidate in
      /opt/homebrew/bin/node|/usr/local/bin/node|/usr/bin/node|\
      /opt/homebrew/bin/git|/usr/local/bin/git|/usr/bin/git|\
      /opt/homebrew/bin/codegraph|/usr/local/bin/codegraph) ;;
      *) IFS=$old_ifs; fail_startup ;;
    esac
  done
done
IFS=$old_ifs

exec /usr/bin/env -i \
  HOME="$parent_home" \
  TMPDIR="$parent_tmp" \
  PATH="$parent_path" \
  CI="${CI-1}" \
  npm_config_offline=true \
  npm_config_audit=false \
  npm_config_fund=false \
  GOPROXY=off \
  GOSUMDB=off \
  GOTOOLCHAIN=local \
  HTTP_PROXY=http://127.0.0.1:9 \
  HTTPS_PROXY=http://127.0.0.1:9 \
  ALL_PROXY=http://127.0.0.1:9 \
  NO_PROXY=127.0.0.1,localhost \
  ORACLE_P0_1_LAUNCHER=posix-v1 \
  ORACLE_P0_1_NODE="$node_executable" \
  ORACLE_P0_1_GIT="$git_executable" \
  ORACLE_P0_1_CODEGRAPH="$codegraph_executable" \
  "$node_executable" "$tsx_cli" "$typescript_entry" "$@"
