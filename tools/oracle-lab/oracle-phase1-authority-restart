#!/bin/sh

fail_startup() {
  printf '%s\n' 'authority_restart_unsafe_startup_environment' >&2
  exit 1
}

for name in \
  NODE_OPTIONS NODE_PATH TSX_TSCONFIG_PATH TSX_DISABLE_CACHE \
  DYLD_INSERT_LIBRARIES DYLD_LIBRARY_PATH LD_PRELOAD \
  GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE GIT_OBJECT_DIRECTORY \
  GIT_ALTERNATE_OBJECT_DIRECTORIES GIT_COMMON_DIR GIT_NAMESPACE \
  GIT_REPLACE_REF_BASE GIT_CONFIG_COUNT GIT_CONFIG_SYSTEM GIT_CONFIG_GLOBAL
do
  eval "is_set=\${$name+x}"
  [ "$is_set" = x ] && fail_startup
done

case $0 in
  /*) launcher=$0 ;;
  *) launcher=$PWD/$0 ;;
esac
script_dir=${launcher%/*}
tool_root=${script_dir%/tools/oracle-lab}
tool_root=$(cd -P "$tool_root" 2>/dev/null && pwd -P) || fail_startup

select_tool() {
  for candidate in "$@"; do
    if [ -x "$candidate" ] && [ ! -d "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

node_executable=$(select_tool /opt/homebrew/bin/node /usr/local/bin/node /usr/bin/node) || fail_startup
git_executable=$(select_tool /opt/homebrew/bin/git /usr/local/bin/git /usr/bin/git) || fail_startup
reviewed_git() {
  /usr/bin/env -i HOME=/dev/null PATH=/usr/bin:/bin LANG=C LC_ALL=C \
    GIT_CONFIG_NOSYSTEM=1 GIT_CONFIG_SYSTEM=/dev/null GIT_CONFIG_GLOBAL=/dev/null \
    GIT_CONFIG_COUNT=0 GIT_NO_REPLACE_OBJECTS=1 GIT_OPTIONAL_LOCKS=0 \
    "$git_executable" -C "$tool_root" "$@"
}

tool_branch=$(reviewed_git symbolic-ref --quiet --short HEAD 2>/dev/null) || fail_startup
case $tool_branch in
  main|codex/*) ;;
  *) fail_startup ;;
esac
tool_upstream=refs/remotes/muqihang/$tool_branch
tool_head=$(reviewed_git rev-parse --verify --end-of-options 'HEAD^{commit}' 2>/dev/null) || fail_startup
reviewed_head=$(reviewed_git rev-parse --verify --end-of-options "$tool_upstream^{commit}" 2>/dev/null) || fail_startup
[ "$tool_head" = "$reviewed_head" ] || fail_startup
[ "$(reviewed_git remote get-url muqihang 2>/dev/null)" = 'https://github.com/muqihang/cc-gateway.git' ] || fail_startup
[ -z "$(reviewed_git status --porcelain=v1 --untracked-files=all --ignore-submodules=none 2>/dev/null)" ] || fail_startup

for file in \
  docs/superpowers/schemas/oracle-lab-phase-1-authority-restart.schema.json \
  tools/oracle-lab/oracle-phase1-authority-restart \
  tools/oracle-lab/phase-1-authority-bootstrap.mjs \
  tools/oracle-lab/phase-1-authority-restart.ts \
  tools/oracle-lab/secure-runtime.ts \
  package.json \
  package-lock.json
do
  [ -f "$tool_root/$file" ] && [ ! -L "$tool_root/$file" ] || fail_startup
  current_oid=$(reviewed_git hash-object -- "$file") || fail_startup
  reviewed_oid=$(reviewed_git rev-parse "$tool_head:$file") || fail_startup
  [ "$current_oid" = "$reviewed_oid" ] || fail_startup
done

umask 077
bootstrap_root=$(/usr/bin/mktemp -d /tmp/oracle-phase1-authority-bootstrap.XXXXXX) || fail_startup
/bin/chmod 700 "$bootstrap_root" || fail_startup
[ -d "$bootstrap_root" ] && [ ! -L "$bootstrap_root" ] || fail_startup
bootstrap_snapshot=$bootstrap_root/phase-1-authority-bootstrap.mjs
reviewed_git show "$tool_head:tools/oracle-lab/phase-1-authority-bootstrap.mjs" > "$bootstrap_snapshot" || fail_startup
/bin/chmod 600 "$bootstrap_snapshot" || fail_startup
[ -f "$bootstrap_snapshot" ] && [ ! -L "$bootstrap_snapshot" ] || fail_startup

exec /usr/bin/env -i \
  HOME=/dev/null TMPDIR=/tmp PATH="${node_executable%/*}:${git_executable%/*}:/usr/bin:/bin" \
  LANG=C LC_ALL=C TZ=UTC \
  ORACLE_PHASE1_AUTHORITY_LAUNCHER=posix-v1 \
  ORACLE_PHASE1_AUTHORITY_BOOTSTRAP=reviewed-git-object-v2 \
  ORACLE_PHASE1_AUTHORITY_TOOL_ROOT="$tool_root" \
  ORACLE_P0_1_NODE="$node_executable" ORACLE_P0_1_GIT="$git_executable" \
  "$node_executable" "$bootstrap_snapshot" "$@"
