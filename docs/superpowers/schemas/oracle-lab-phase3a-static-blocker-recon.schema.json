      "properties": {
        "missing_exact_state_protocol": {"const": "CLOSED"}, "missing_state_dependent_network_signal": {"const": "CLOSED"},
        "evidence_basis": {"const": "independently-reproducible-static-anchor-and-safe-metadata-record"}, "lifecycle": {"const": "RECON_APPEND_ONLY_CLOSED"},
        "independent_review_gate": {"const": "required-on-immutable-tip-before-any-controller-decision"}, "controller_creation_authorized": {"const": false},
        "dynamic_execution_authorized": {"const": false}, "phase3b_usable": {"const": false}, "next_action": {"const": "separate-reviewed-controller-creation-decision-only"}
      }
    }
  }
