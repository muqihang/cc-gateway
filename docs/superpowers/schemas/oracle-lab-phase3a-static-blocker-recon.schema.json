          {"from":"state-file-resolver","to":"state-read-resolver-bridge","relation":"resolved-path-argument"},
          {"from":"state-jsonl-reader","to":"state-read-resolver-bridge","relation":"parsed-state-return"},
          {"from":"state-read-resolver-bridge","to":"state-message-reconstructor","relation":"state-map-return"},
          {"from":"state-message-reconstructor","to":"resume-loader","relation":"reconstructed-conversation-return"},
          {"from":"resume-loader","to":"print-resume-router","relation":"resume-state-return"},
          {"from":"print-resume-router","to":"headless-resume-bridge","relation":"messages-return"},
          {"from":"headless-resume-bridge","to":"headless-message-runner","relation":"messages-argument"},
          {"from":"headless-message-runner","to":"message-transport-bridge","relation":"nested-callback-messages"},
          {"from":"message-transport-bridge","to":"query-message-input","relation":"initial-to-mutable-messages"},
          {"from":"query-message-input","to":"query-generator-bridge","relation":"mutable-copy-plus-current-input"},
          {"from":"query-generator-bridge","to":"query-pipeline","relation":"query-input"},
          {"from":"query-pipeline","to":"default-model-dispatch","relation":"dependency-construction"},
          {"from":"default-model-dispatch","to":"model-call-bridge","relation":"call-model-binding"},
          {"from":"model-call-bridge","to":"network-request-sink","relation":"nested-generator-request"},
          {"from":"network-request-sink","to":"request-normalizer","relation":"message-normalization"},
          {"from":"network-request-sink","to":"request-serializer","relation":"request-builder-serialization"},
          {"from":"network-request-sink","to":"sdk-message-post-route","relation":"sdk-method-dispatch"}
        ]},
        "fresh_resume_discriminator": {"const": {"creation_expected":"creation-request-plus-response-safe-conversation-topology","fresh_expected":"current-input-only-no-predecessor-prefix","resume_expected":"ordered-predecessor-prefix-before-final-current-input","minimum_predecessor_assistant_entries":1,"comparison":"resume-prefix-equals-creation-safe-exchange-projection"}},
        "projection_algorithm": {"const": {"version":"p3as-predecessor-prefix-projection-v1","input":"loopback-fake-upstream-request-json-ast-$.messages","ordered_steps":["parse-request-body-as-json","select-messages-array","map-each-message-to-role-and-ordered-content-block-shape-without-values","split-final-message-as-current-input","require-nonempty-predecessor-prefix","compare-resume-predecessor-prefix-to-creation-safe-exchange-projection"],"canonicalization":"RFC8785-JCS","current_input_position":"final-array-element","minimum_predecessor_assistant_entries":1,"raw_values_persisted":false}},
        "safe_projection": {"const": {"allowed_fields":["array-cardinality","content-block-count","content-block-order","content-block-type","object-field-name-class","role-order","sse-event-class-order"],"raw_values_persisted":false,"session_ids_persisted":false,"credentials_persisted":false,"headers_persisted":false,"body_bytes_persisted":false}},
        "signal_anchor_digest": {"$ref": "#/$defs/sha256"}, "derivation_digest": {"$ref": "#/$defs/sha256"},
        "observer_a": {"const": {"observer_kind":"network-state-signal","capture_surface":"loopback-fake-upstream-http-json-ast-and-sse-topology","parser_class":"http-json-ast-safe-projector","proves":"predecessor-conversation-topology-reached-target-generated-request","failure_mode":"request-or-ast-or-sse-capture-missing-or-mismatched"}},
        "observer_b": {"const": {"observer_kind":"darwin-state-process","capture_surface":"darwin-vnode-open-read-plus-process-start-attribution","parser_class":"filesystem-process-event-safe-projector","proves":"exact-predecessor-jsonl-was-opened-read-by-bound-target-process","failure_mode":"vnode-event-or-pid-start-or-executable-attribution-missing-or-mismatched"}},
        "proof_rule": {"$ref": "#/$defs/proofRule"}, "negative_controls": {"type": "array", "minItems": 6, "items": {"$ref": "#/$defs/negativeControl"}}
      }
    },
    "requestSurface": {
      "type": "object", "additionalProperties": false, "required": ["method", "path_class", "ast_location", "terminal_sink", "base_url_source"],
      "properties": {"method": {"const": "POST"}, "path_class": {"const": "/v1/messages"}, "ast_location": {"const": "$.messages"}, "terminal_sink": {"const": "beta.messages.create"}, "base_url_source": {"const": "ANTHROPIC_BASE_URL-bound-fake-upstream-endpoint-safe-ref"}}
    },
    "flowEdge": {
