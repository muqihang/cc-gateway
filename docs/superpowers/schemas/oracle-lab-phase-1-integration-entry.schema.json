        "head": {
          "type": "string",
          "pattern": "^[0-9a-f]{40,64}$"
        },
        "origin_url_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "root_identity_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "clean_status_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "contract_relative_path": {
          "const": "backend/internal/service/testdata/cc_gateway_formal_pool_contract/vectors.json"
        },
        "contract_digest": {
          "const": "sha256:70c26db06e9135db31d08f097573e3fd55bd9a8894614832eefeecabf6b1a3d1"
        }
      }
    },
    "implementation_trees": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cc_gateway", "sub2api"],
      "properties": {
        "cc_gateway": {"$ref": "#/$defs/implementation_tree"},
        "sub2api": {"$ref": "#/$defs/implementation_tree"}
      }
    },
    "ignored_state_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["results_path", "results_digest", "chain_digest", "final"],
      "properties": {
        "results_path": {"$ref": "#/$defs/relative_path"},
        "results_digest": {"$ref": "#/$defs/digest"},
        "chain_digest": {"$ref": "#/$defs/digest"},
        "final": {"$ref": "#/$defs/ignored_state_set"}
      }
    },
    "external_dependency_reference": {"$ref": "#/$defs/external_dependency_reference"},
    "sandbox_policy_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "shared_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "path",
        "digest"
      ],
      "properties": {
        "repository": {
          "const": "sub2api"
        },
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "disabled_capabilities": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "uniqueItems": true,
      "items": {
        "enum": [
          "real_upstream_access",
          "real_credentials",
          "provider_internal_authority",
          "profile_promotion",
          "production_deployment",
          "real_canary",
          "direct_egress_trust",
          "unverified_pinned_wire_claims",
          "unsupported_negative_capabilities",
          "expired_or_missing_negative_capabilities",
          "unrestricted_capture",
          "external_network_requests"
        ]
      }
    },
    "entry_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40,64}$"
    },
    "relative_path": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
    },
    "path_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "digest"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "implementation_tree": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "repository",
        "source_commit",
        "exclusion_policy",
        "excluded_prefixes",
        "excluded_paths",
        "entry_count",
        "entries_digest"
      ],
      "properties": {
        "algorithm": {
          "const": "git_ls_tree_v1_sha256_canonical_json"
        },
        "repository": {
          "enum": [
            "cc_gateway",
            "sub2api"
          ]
        },
        "source_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40,64}$"
        },
        "exclusion_policy": {
          "const": "phase1_evidence_governance_only_v1"
        },
        "excluded_prefixes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
          }
        },
        "excluded_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
          }
        },
        "entry_count": {
          "type": "integer",
          "minimum": 0
        },
        "entries_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
