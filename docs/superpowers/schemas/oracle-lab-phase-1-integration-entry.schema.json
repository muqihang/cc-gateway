{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oracle.local/schemas/oracle-lab-phase-1-integration-entry.json",
  "title": "Oracle Lab Phase 1 Integration Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "entry_kind",
    "generated_at",
    "expires_at",
    "attempt",
    "catalog",
    "context",
    "plan_review",
    "feature_results",
    "feature_review",
    "review_attestation_head",
    "candidate_heads",
    "merge_topology",
    "remote_mains",
    "roots",
    "sub2api_contract_root",
    "implementation_trees",
    "ignored_state_reference",
    "external_dependency_reference",
    "sandbox_policy_digest",
    "shared_contract",
    "disabled_capabilities",
    "entry_digest"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "entry_kind": {
      "const": "phase_1_integration_entry"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attempt_id",
        "sequence",
        "predecessor"
      ],
      "properties": {
        "attempt_id": {
          "type": "string",
          "pattern": "^attempt-[0-9]{4}$"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "predecessor": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "attempt_id",
                "receipt",
                "receipt_commit"
              ],
              "properties": {
                "attempt_id": {
                  "type": "string",
                  "pattern": "^attempt-[0-9]{4}$"
                },
                "receipt": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "path",
                    "digest"
                  ],
                  "properties": {
                    "path": {
                      "type": "string",
                      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
                    },
                    "digest": {
                      "type": "string",
                      "pattern": "^sha256:[0-9a-f]{64}$"
                    }
                  }
                },
                "receipt_commit": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{40,64}$"
                }
              }
            }
          ]
        }
      }
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "digest"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "digest",
        "sequence",
        "stage",
        "artifact_commit"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "stage": {
          "enum": [
            "implementation_entry",
            "implementation",
            "feature_capture",
            "post_integration"
          ]
        },
        "artifact_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40,64}$"
        }
      }
    },
    "plan_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "digest"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "feature_results": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "digest"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "feature_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "digest"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "review_attestation_head": {
      "type": "string",
      "pattern": "^[0-9a-f]{40,64}$"
    },
    "candidate_heads": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cc_gateway", "sub2api"],
      "properties": {
        "cc_gateway": {"$ref": "#/$defs/commit"},
        "sub2api": {"$ref": "#/$defs/commit"}
      }
    },
    "merge_topology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cc", "sub2api"],
      "properties": {
        "cc": {"$ref": "#/$defs/merge_topology_item"},
        "sub2api": {"$ref": "#/$defs/merge_topology_item"}
      }
    },
    "remote_mains": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cc_gateway", "sub2api"],
      "properties": {
        "cc_gateway": {"$ref": "#/$defs/remote_main"},
        "sub2api": {"$ref": "#/$defs/remote_main"}
      }
    },
    "roots": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "controller",
        "cc_gateway",
        "sub2api"
      ],
      "properties": {
        "controller": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "stage",
            "head",
            "root_identity_digest",
            "same_as_tested_cc_root",
            "preexisting_delta_paths",
            "declared_output_paths"
          ],
          "properties": {
            "stage": {
              "enum": [
                "feature-candidate",
                "post-integration"
              ]
            },
            "head": {
              "type": "string",
              "pattern": "^[0-9a-f]{40,64}$"
            },
            "root_identity_digest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            },
            "same_as_tested_cc_root": {
              "type": "boolean"
            },
            "preexisting_delta_paths": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
              }
            },
            "declared_output_paths": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
              }
            }
          }
        },
        "cc_gateway": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "head",
            "root_identity_digest",
            "clean_status_digest"
          ],
          "properties": {
            "head": {
              "type": "string",
              "pattern": "^[0-9a-f]{40,64}$"
            },
            "root_identity_digest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            },
            "clean_status_digest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          }
        },
        "sub2api": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "head",
            "root_identity_digest",
            "clean_status_digest"
          ],
          "properties": {
            "head": {
              "type": "string",
              "pattern": "^[0-9a-f]{40,64}$"
            },
            "root_identity_digest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            },
            "clean_status_digest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          }
        }
      }
    },
    "sub2api_contract_root": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "clone_kind",
        "branch",
        "head",
        "origin_url_digest",
        "root_identity_digest",
        "clean_status_digest",
        "contract_relative_path",
        "contract_digest"
