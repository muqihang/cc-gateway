{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-gateway.local/schemas/oracle-lab-claim.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["claim_id", "requirement_ids", "claim_class", "authority_state", "statement", "evidence_ids", "observation_scope", "server_dependency", "stability_class", "confidence", "contradiction_ids", "expiry", "canary_evidence_ids", "production_gate_ids", "rollback_evidence_ids", "deployed_artifacts", "derived_from", "authoritative_provider_disclosure"],
    "properties": {
      "claim_id": {"type": "string", "pattern": "^CL-[A-Z0-9]+(?:-[A-Z0-9]+)*$"},
      "requirement_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
      "claim_class": {"enum": ["local_structural", "local_observational", "upstream_canary", "provider_internal"]},
      "authority_state": {"enum": ["unverified", "package_observed", "local_wire_observed", "cross_checked", "gateway_wire_equivalent", "stateful_behavior_equivalent", "upstream_canary_observed", "production_verified"]},
      "statement": {"type": "string", "minLength": 1},
      "evidence_ids": {"type": "array", "items": {"type": "string"}},
      "observation_scope": {"enum": ["package", "local", "local_wire", "cross_checked", "gateway", "stateful", "upstream_canary", "production"]},
      "server_dependency": {"enum": ["none", "local", "server", "provider"]},
      "stability_class": {"type": "string", "minLength": 1},
      "confidence": {"type": "number", "minimum": 0, "maximum": 1},
      "contradiction_ids": {"type": "array", "items": {"type": "string"}},
      "expiry": {"type": ["string", "null"], "format": "date-time"},
      "canary_evidence_ids": {"type": "array", "items": {"type": "string"}},
      "production_gate_ids": {"type": "array", "items": {"type": "string"}},
      "rollback_evidence_ids": {"type": "array", "items": {"type": "string"}},
      "deployed_artifacts": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["repository", "commit", "config_digest", "manifest_digest", "deployed_at"], "properties": {"repository": {"type": "string"}, "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "config_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "manifest_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "deployed_at": {"type": "string", "format": "date-time"}}}},
      "derived_from": {"type": "string", "minLength": 1},
      "authoritative_provider_disclosure": {"type": "boolean"}
    },
    "allOf": [
      {"if": {"properties": {"claim_class": {"enum": ["local_structural"]}}}, "then": {"properties": {"authority_state": {"enum": ["unverified", "package_observed", "local_wire_observed", "cross_checked", "gateway_wire_equivalent"]}}}},
      {"if": {"properties": {"claim_class": {"enum": ["local_observational"]}}}, "then": {"properties": {"authority_state": {"enum": ["unverified", "package_observed", "local_wire_observed", "cross_checked", "gateway_wire_equivalent", "stateful_behavior_equivalent"]}}}},
      {"if": {"properties": {"authority_state": {"const": "production_verified"}}}, "then": {"properties": {"claim_class": {"enum": ["upstream_canary", "provider_internal"]}, "observation_scope": {"const": "production"}, "canary_evidence_ids": {"minItems": 1}, "production_gate_ids": {"minItems": 1}, "rollback_evidence_ids": {"minItems": 1}, "deployed_artifacts": {"minItems": 1}, "contradiction_ids": {"maxItems": 0}, "expiry": {"type": "string", "format": "date-time"}}}, "else": {"properties": {"canary_evidence_ids": {"maxItems": 0}, "production_gate_ids": {"maxItems": 0}, "rollback_evidence_ids": {"maxItems": 0}, "deployed_artifacts": {"maxItems": 0}, "expiry": {"type": "null"}}}}
    ]
  }
}
