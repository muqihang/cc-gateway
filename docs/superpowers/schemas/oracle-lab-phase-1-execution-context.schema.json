{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Oracle Lab Phase 1 Execution Context",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "context_kind",
    "context_mode",
    "sequence",
    "stage",
    "artifact_path",
    "predecessor",
    "generated_at",
    "expires_at",
    "plan",
    "approval_receipt",
    "gate_schemas",
    "repositories",
    "shared_contract",
    "authority_order",
    "selected_requirements",
    "implementation_entry",
    "disabled_capabilities"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "context_kind": {"enum": ["phase_1_execution_context", "phase_1_recovery_context"]},
    "context_mode": {"enum": ["initial", "successor"]},
    "sequence": {"type": "integer", "minimum": 0, "maximum": 9999},
    "stage": {"enum": ["implementation_entry", "implementation", "feature_capture"]},
    "artifact_path": {
      "oneOf": [
        {"const": "docs/superpowers/evidence/phase-1/phase-1-execution-context.json"},
        {"type": "string", "pattern": "^docs/superpowers/evidence/phase-1/phase-1-execution-context-[0-9]{4}\\.json$"}
      ]
    },
    "predecessor": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/predecessor"}
      ]
    },
    "generated_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "digest", "reviewed_commit"],
      "properties": {
        "path": {"enum": ["docs/superpowers/plans/2026-07-15-claude-code-2.1.207-phase-1-control-plane-boundary-repairs.md", "docs/superpowers/plans/2026-07-18-claude-code-2.1.207-phase-1-recovery.md"]},
        "digest": {"$ref": "#/$defs/digest"},
        "reviewed_commit": {"$ref": "#/$defs/commit"}
      }
    },
    "planning_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entry", "context"],
      "properties": {
        "entry": {
          "allOf": [
            {"$ref": "#/$defs/path_digest"},
            {"properties": {"path": {"const": "docs/superpowers/evidence/phase-1/phase-1-entry-baseline.json"}}}
          ]
        },
        "context": {
          "allOf": [
            {"$ref": "#/$defs/path_digest"},
            {"properties": {"path": {"const": "docs/superpowers/evidence/phase-1/phase-1-context.json"}}}
          ]
        }
      }
    },
    "recovery_authority": {"$ref": "#/$defs/recovery_authority"},
    "approval_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact", "decision", "reviewer_id", "review_round", "reviewed_plan_commit", "reviewed_plan_digest", "critical_findings", "important_findings"],
      "properties": {
        "artifact": {
          "allOf": [
            {"$ref": "#/$defs/path_digest"},
            {"properties": {"path": {"const": "docs/superpowers/evidence/phase-1/phase-1-plan-review.json"}}}
          ]
        },
        "decision": {"const": "approved"},
        "reviewer_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"},
        "review_round": {"type": "integer", "minimum": 1},
        "reviewed_plan_commit": {"$ref": "#/$defs/commit"},
        "reviewed_plan_digest": {"$ref": "#/$defs/digest"},
        "critical_findings": {"const": 0},
        "important_findings": {"const": 0},
        "reviewer_roles": {"const": ["product", "authority"]}
      }
    },
    "gate_schemas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execution_context", "plan_review"],
      "properties": {
        "execution_context": {
          "allOf": [
            {"$ref": "#/$defs/path_digest"},
            {"properties": {"path": {"const": "docs/superpowers/schemas/oracle-lab-phase-1-execution-context.schema.json"}}}
          ]
        },
        "plan_review": {
          "allOf": [
            {"$ref": "#/$defs/path_digest"},
            {"properties": {"path": {"const": "docs/superpowers/schemas/oracle-lab-phase-1-plan-review.schema.json"}}}
          ]
        }
      }
    },
    "repositories": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cc_gateway", "sub2api"],
      "properties": {
        "cc_gateway": {
          "allOf": [
            {"$ref": "#/$defs/repository"},
            {"properties": {"remote_url_digest": {"const": "sha256:52de8ee497a784b90b33345865754f3e6b9d5d96eed92549a15a4157cabb568a"}}}
          ]
        },
        "sub2api": {
          "allOf": [
            {"$ref": "#/$defs/repository"},
            {"properties": {"remote_url_digest": {"const": "sha256:22c1a9e3cf8e76d2a20bf24a1ff66fa5d7417ba8b8b83a948c8b3ffa5c33a1a9"}}}
          ]
        }
      }
    },
    "shared_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "path", "digest"],
      "properties": {
        "repository": {"const": "sub2api"},
        "path": {"const": "backend/internal/service/testdata/cc_gateway_formal_pool_contract/vectors.json"},
        "digest": {"const": "sha256:70c26db06e9135db31d08f097573e3fd55bd9a8894614832eefeecabf6b1a3d1"}
      }
    },
    "authority_order": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "prefixItems": [
        {
          "allOf": [
            {"$ref": "#/$defs/path_digest"},
            {"properties": {"path": {"const": "docs/superpowers/specs/2026-07-12-claude-code-2.1.207-oracle-lab-review-amendments.md"}}}
          ]
        },
        {
          "allOf": [
            {"$ref": "#/$defs/path_digest"},
            {"properties": {"path": {"const": "docs/superpowers/specs/2026-07-11-claude-code-2.1.207-oracle-lab-hardening-amendments.md"}}}
          ]
        },
        {
          "allOf": [
            {"$ref": "#/$defs/path_digest"},
            {"properties": {"path": {"const": "docs/superpowers/specs/2026-07-11-claude-code-2.1.207-adversarial-validation-v2.md"}}}
          ]
        },
        {
          "allOf": [
            {"$ref": "#/$defs/path_digest"},
            {"properties": {"path": {"const": "docs/superpowers/specs/2026-07-11-claude-code-2.1.207-oracle-lab-design.md"}}}
          ]
        }
      ],
      "items": false
    },
    "selected_requirements": {"const": ["AV-B1-001", "AV-B2-001", "AV-B3-001", "RA-P0-008"]},
    "implementation_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "conditions"],
      "properties": {
        "status": {"const": "authorized"},
        "conditions": {
          "const": [
            "fresh_unexpired_execution_context",
            "contiguous_immutable_context_chain",
            "exact_stage_and_repository_state",
            "exact_plan_digest_bound",
            "independent_plan_approval_bound",
            "critical_and_important_findings_zero",
            "both_main_heads_frozen",
            "shared_contract_unchanged",
            "production_and_real_canary_disabled"
          ]
        }
      }
    },
    "disabled_capabilities": {
      "const": [
        "real_upstream_access",
        "real_credentials",
        "provider_internal_authority",
        "profile_promotion",
        "production_deployment",
        "real_canary",
        "direct_egress_trust",
        "unverified_pinned_wire_claims",
        "unsupported_negative_capabilities",
        "expired_or_missing_negative_capabilities",
        "unrestricted_capture",
        "external_network_requests"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"context_kind": {"const": "phase_1_recovery_context"}},
        "required": ["context_kind"]
      },
      "then": {
        "required": ["recovery_authority"],
        "not": {"required": ["planning_provenance"]},
        "properties": {
          "plan": {
            "properties": {
              "path": {"const": "docs/superpowers/plans/2026-07-18-claude-code-2.1.207-phase-1-recovery.md"},
              "digest": {"const": "sha256:8c1d2a9ec1532f30d241a41d00d24998d37ac1f0babb45cd5b945a7c2405fcf2"},
              "reviewed_commit": {"const": "48b9fae0da983077ae81d1164ccb693586a2ab4e"}
            }
          },
          "approval_receipt": {
            "required": ["reviewer_roles"],
            "properties": {
              "reviewer_id": {"const": "phase1-recovery-acceptance-review"},
              "reviewed_plan_commit": {"const": "48b9fae0da983077ae81d1164ccb693586a2ab4e"},
              "reviewed_plan_digest": {"const": "sha256:8c1d2a9ec1532f30d241a41d00d24998d37ac1f0babb45cd5b945a7c2405fcf2"}
            }
          },
          "repositories": {
            "properties": {
              "cc_gateway": {"properties": {"implementation_branch": {"const": "codex/oracle-phase-1-recovery-cc"}}},
              "sub2api": {"properties": {"implementation_branch": {"const": "codex/oracle-phase-1-recovery-sub2api"}}}
            }
          }
        }
      },
      "else": {
        "required": ["planning_provenance"],
        "not": {"anyOf": [{"required": ["recovery_authority"]}, {"properties": {"approval_receipt": {"required": ["reviewer_roles"]}}}]},
        "properties": {
          "context_kind": {"const": "phase_1_execution_context"},
          "plan": {"properties": {"path": {"const": "docs/superpowers/plans/2026-07-15-claude-code-2.1.207-phase-1-control-plane-boundary-repairs.md"}}},
          "repositories": {
            "properties": {
              "cc_gateway": {"properties": {"implementation_branch": {"const": "codex/oracle-phase-1-cc-gateway-v8"}}},
              "sub2api": {"properties": {"implementation_branch": {"const": "codex/oracle-phase-1-sub2api-v8"}}}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"context_mode": {"const": "initial"}},
        "required": ["context_mode"]
      },
      "then": {
        "properties": {
          "sequence": {"const": 0},
          "stage": {"const": "implementation_entry"},
          "artifact_path": {"const": "docs/superpowers/evidence/phase-1/phase-1-execution-context.json"},
          "predecessor": {"type": "null"}
        }
      },
      "else": {
        "properties": {
          "context_mode": {"const": "successor"},
          "sequence": {"type": "integer", "minimum": 1, "maximum": 9999},
          "stage": {"enum": ["implementation", "feature_capture"]},
          "artifact_path": {"type": "string", "pattern": "^docs/superpowers/evidence/phase-1/phase-1-execution-context-[0-9]{4}\\.json$"},
          "predecessor": {"$ref": "#/$defs/predecessor"}
        }
      }
    }
  ],
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "commit": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
    "path_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "digest"],
      "properties": {
        "path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
        "digest": {"$ref": "#/$defs/digest"}
      }
    },
    "predecessor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "digest", "sequence", "stage", "artifact_commit"],
      "properties": {
        "path": {
          "oneOf": [
            {"const": "docs/superpowers/evidence/phase-1/phase-1-execution-context.json"},
            {"type": "string", "pattern": "^docs/superpowers/evidence/phase-1/phase-1-execution-context-[0-9]{4}\\.json$"}
          ]
        },
        "digest": {"$ref": "#/$defs/digest"},
        "sequence": {"type": "integer", "minimum": 0, "maximum": 9998},
        "stage": {"enum": ["implementation_entry", "implementation", "feature_capture"]},
        "artifact_commit": {"$ref": "#/$defs/commit"}
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline_main_head", "authorized_parent_head", "observed_remote_main_head", "remote_name", "remote_url_digest", "tracking_ref", "implementation_branch", "pre_issue_clean", "validation_status"],
      "properties": {
        "baseline_main_head": {"$ref": "#/$defs/commit"},
        "authorized_parent_head": {"$ref": "#/$defs/commit"},
        "observed_remote_main_head": {"$ref": "#/$defs/commit"},
        "remote_name": {"const": "muqihang"},
        "remote_url_digest": {"$ref": "#/$defs/digest"},
        "tracking_ref": {"const": "refs/remotes/muqihang/main"},
        "implementation_branch": {"type": "string", "minLength": 1},
        "pre_issue_clean": {"const": true},
        "validation_status": {"$ref": "#/$defs/validation_status"}
      }
    },
    "validation_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entries", "digest"],
      "properties": {
        "entries": {
          "type": "array",
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^\\?\\? docs/superpowers/evidence/phase-1/[A-Za-z0-9._/-]+$"
          }
        },
        "digest": {"$ref": "#/$defs/digest"}
      }
    },
    "recovery_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operating_model", "roadmap", "transition_plan", "transition_exit_report", "terminal_controller_chain", "terminal_acceptance_record", "recovery_contract", "source_bundles", "shared_contract"],
      "properties": {
        "operating_model": {"allOf": [{"$ref": "#/$defs/path_digest"}, {"properties": {"path": {"const": "docs/superpowers/roadmaps/2026-07-18-oracle-lab-delivery-operating-model-v2.md"}, "digest": {"const": "sha256:a53e7384d6cf353877af82f16196b8d58ed823277e76e03337dfc9fadff7d0ea"}}}]},
        "roadmap": {"allOf": [{"$ref": "#/$defs/path_digest"}, {"properties": {"path": {"const": "docs/superpowers/roadmaps/2026-07-11-claude-code-2.1.207-oracle-lab-roadmap.md"}, "digest": {"const": "sha256:00519348d9dd8972dbea92a647d67c2fc42e9015ece6dcb0eb427df02480b107"}}}]},
        "transition_plan": {"allOf": [{"$ref": "#/$defs/path_digest"}, {"properties": {"path": {"const": "docs/superpowers/plans/2026-07-18-oracle-delivery-mechanism-transition.md"}, "digest": {"const": "sha256:f21023b1d6705855e00ee0f9ceafc78c6cf1c7b928982fd88e821faffa7a8111"}}}]},
        "transition_exit_report": {"allOf": [{"$ref": "#/$defs/path_digest"}, {"properties": {"path": {"const": "docs/superpowers/evidence/delivery-model/delivery-mechanism-transition-exit-report.md"}, "digest": {"const": "sha256:44c9322ba157c1ce4f3b9a974387026aad143f73c6991848be3f50f13af00f48"}}}]},
        "terminal_controller_chain": {"allOf": [{"$ref": "#/$defs/controller_digest"}, {"properties": {"kind": {"const": "terminal_controller_chain"}, "digest": {"const": "sha256:3faa939ec6f78a7478a5ea5c2773ea74d5ea42d0b699e1880798cac980192433"}}}]},
        "terminal_acceptance_record": {"allOf": [{"$ref": "#/$defs/controller_digest"}, {"properties": {"kind": {"const": "terminal_acceptance_record"}, "digest": {"const": "sha256:00f84b989d0db40d0c47429bcd5d444709159027f21f4dec0e33812b9c539ecd"}}}]},
        "recovery_contract": {
          "type": "object", "additionalProperties": false, "required": ["plan_path", "digest"],
          "properties": {"plan_path": {"const": "docs/superpowers/plans/2026-07-18-claude-code-2.1.207-phase-1-recovery.md"}, "digest": {"const": "sha256:4fb422c47b62519552fe1d21dee53576309df145c280d05c41d575bfdb82c3fe"}}
        },
        "source_bundles": {
          "type": "object", "additionalProperties": false, "required": ["cc_gateway", "sub2api"],
          "properties": {"cc_gateway": {"const": "sha256:27e9e3cea6a2d18eb1e6423e9e7589aa53b5779fcf71a55008bbdbca838c9fd3"}, "sub2api": {"const": "sha256:3df0933834ed3bcc692b421e317c19314c1594492571a4abeae84375152fe47e"}}
        },
        "shared_contract": {
          "type": "object", "additionalProperties": false, "required": ["path", "digest"],
          "properties": {"path": {"const": "backend/internal/service/testdata/cc_gateway_formal_pool_contract/vectors.json"}, "digest": {"const": "sha256:70c26db06e9135db31d08f097573e3fd55bd9a8894614832eefeecabf6b1a3d1"}}
        }
      }
    },
    "controller_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "digest"],
      "properties": {
        "kind": {"enum": ["terminal_controller_chain", "terminal_acceptance_record"]},
        "digest": {"$ref": "#/$defs/digest"}
      }
    }
  }
}
