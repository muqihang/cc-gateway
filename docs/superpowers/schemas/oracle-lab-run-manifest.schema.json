{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "oracle-lab-run-manifest.schema.json",
  "title": "Oracle Lab Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "compatibility_policy",
    "retention_class",
    "redaction_policy",
    "destruction_procedure",
    "phase",
    "approved_tool_head",
    "repositories",
    "contract",
    "governance",
    "policies",
    "dependencies",
    "codegraph",
    "legacy_comparison"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "compatibility_policy": { "const": "fail_closed_exact_schema" },
    "retention_class": { "const": "phase_evidence_permanent" },
    "redaction_policy": { "const": "digests_and_safe_categories_only" },
    "destruction_procedure": { "const": "git_revert_artifact_commit_after_security_approval" },
    "phase": { "enum": ["phase_0_entry", "phase_0_exit"] },
    "approved_tool_head": { "$ref": "#/$defs/gitCommit" },
    "repositories": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cc_gateway", "sub2api"],
      "properties": {
        "cc_gateway": { "$ref": "#/$defs/repository" },
        "sub2api": { "$ref": "#/$defs/repository" }
      }
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path_category", "repository_relative_path_base64url", "sha256"],
      "properties": {
        "path_category": { "const": "sub2api_formal_pool_contract" },
        "repository_relative_path_base64url": { "type": "string" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "governance": {
      "type": "object", "additionalProperties": false,
      "required": ["requirement_registry", "claim_registry"],
      "properties": { "requirement_registry": { "$ref": "#/$defs/governanceMarker" }, "claim_registry": { "$ref": "#/$defs/governanceMarker" } }
    },
    "policies": {
      "type": "object", "additionalProperties": false, "required": ["network", "sensitivity"],
      "properties": {
        "network": { "type": "object", "additionalProperties": false, "required": ["real_upstream_requests", "local_fixture_only"], "properties": { "real_upstream_requests": { "const": "forbidden" }, "local_fixture_only": { "const": true } } },
        "sensitivity": { "type": "object", "additionalProperties": false, "required": ["persisted_material", "forbidden"], "properties": { "persisted_material": { "const": "safe_categories_and_sha256_digests_only" }, "forbidden": { "type": "array", "items": { "type": "string" } } } }
      }
    },
    "dependencies": { "type": "object", "additionalProperties": false, "required": ["persona_registry", "persona_resolver", "request_policy", "tls_registry", "cch_request_construction", "sidecar_profile", "sidecar_summary", "package_manifest", "package_lock", "sidecar_go_manifest", "sidecar_go_lock", "repository_root_metadata", "tools", "observer_parser_canonicalizer", "runtime_toolchain"], "properties": { "persona_registry": { "$ref": "#/$defs/digestMarker" }, "persona_resolver": { "$ref": "#/$defs/digestMarker" }, "request_policy": { "$ref": "#/$defs/digestMarker" }, "tls_registry": { "$ref": "#/$defs/digestMarker" }, "cch_request_construction": { "$ref": "#/$defs/digestMarker" }, "sidecar_profile": { "$ref": "#/$defs/digestMarker" }, "sidecar_summary": { "$ref": "#/$defs/digestMarker" }, "package_manifest": { "$ref": "#/$defs/digestMarker" }, "package_lock": { "$ref": "#/$defs/digestMarker" }, "sidecar_go_manifest": { "$ref": "#/$defs/digestMarker" }, "sidecar_go_lock": { "$ref": "#/$defs/digestMarker" }, "repository_root_metadata": { "type": "object", "additionalProperties": false, "required": ["cc_gateway_augmentroot", "sub2api_augmentroot"], "properties": { "cc_gateway_augmentroot": { "$ref": "#/$defs/digestMarker" }, "sub2api_augmentroot": { "$ref": "#/$defs/digestMarker" } } }, "tools": { "type": "array", "items": { "$ref": "#/$defs/pathDigest" } }, "observer_parser_canonicalizer": { "type": "array", "items": { "$ref": "#/$defs/pathDigest" } }, "runtime_toolchain": { "type": "object", "additionalProperties": false, "required": ["node", "git", "npm", "go"], "properties": { "node": { "type": "string" }, "git": { "type": "string" }, "npm": { "type": "string" }, "go": { "$ref": "#/$defs/toolDigest" } } } } },
    "codegraph": { "type": "object", "additionalProperties": false, "required": ["status"], "properties": { "status": { "enum": ["present", "absent"] }, "index_sha256": { "$ref": "#/$defs/sha256" }, "fallback_reason": { "type": "string" } } },
    "legacy_comparison": { "type": "object", "additionalProperties": false, "required": ["requirement_id", "version", "authority", "use", "promotion_eligible", "tuple_digests"], "properties": { "requirement_id": { "const": "OL-LEGACY-001" }, "version": { "const": "2.1.197" }, "authority": { "const": "unverified_legacy" }, "use": { "const": "comparison_only" }, "promotion_eligible": { "const": false }, "tuple_digests": { "type": "object", "additionalProperties": false, "required": ["persona", "request_shape", "cch", "tls"], "properties": { "persona": { "$ref": "#/$defs/digestMarker" }, "request_shape": { "$ref": "#/$defs/digestMarker" }, "cch": { "$ref": "#/$defs/digestMarker" }, "tls": { "$ref": "#/$defs/digestMarker" } } } } }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "gitCommit": { "type": "string", "pattern": "^[0-9a-f]{40,64}$" },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["head", "branch", "clean", "dirty_digest", "dirty_records", "ignored_exclusion_rules"],
      "properties": {
        "head": { "$ref": "#/$defs/gitCommit" },
        "branch": { "type": "string" },
        "clean": { "type": "boolean" },
        "dirty_digest": { "$ref": "#/$defs/sha256" },
        "dirty_record_format": { "type": "string" },
        "ignored_exclusion_rules": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["source_category", "rule_sha256"], "properties": { "source_category": { "type": "string" }, "source_path_base64url": { "type": "string" }, "rule_sha256": { "$ref": "#/$defs/sha256" } } } },
        "dirty_records": { "type": "array", "items": { "$ref": "#/$defs/dirtyRecord" } }
      }
    },
    "governanceMarker": { "oneOf": [{ "type": "object", "additionalProperties": false, "required": ["status"], "properties": { "status": { "const": "absent_pre_governance_bootstrap" } } }, { "type": "object", "additionalProperties": false, "required": ["status", "sha256"], "properties": { "status": { "const": "present" }, "sha256": { "$ref": "#/$defs/sha256" } } }] },
    "digestMarker": { "oneOf": [{ "type": "object", "additionalProperties": false, "required": ["status", "sha256"], "properties": { "status": { "const": "present" }, "sha256": { "$ref": "#/$defs/sha256" } } }, { "type": "object", "additionalProperties": false, "required": ["status", "reason"], "properties": { "status": { "const": "absent" }, "reason": { "type": "string" } } }] },
    "pathDigest": { "type": "object", "additionalProperties": false, "required": ["path_base64url", "sha256"], "properties": { "path_base64url": { "type": "string" }, "sha256": { "$ref": "#/$defs/sha256" } } },
    "toolDigest": { "oneOf": [{ "type": "object", "additionalProperties": false, "required": ["status", "sha256", "provenance"], "properties": { "status": { "const": "present" }, "sha256": { "$ref": "#/$defs/sha256" }, "provenance": { "type": "string", "minLength": 1 } } }, { "type": "object", "additionalProperties": false, "required": ["status", "reason", "required"], "properties": { "status": { "const": "absent" }, "reason": { "const": "tool_not_found" }, "required": { "type": "boolean" } } }] },
    "dirtyRecord": { "type": "object", "additionalProperties": false, "required": ["status", "destination_path_base64url", "object_type", "file_mode"], "properties": { "status": { "type": "string" }, "destination_path_base64url": { "type": "string" }, "source_path_base64url": { "type": "string" }, "object_type": { "type": "string" }, "file_mode": { "type": "string" }, "content_sha256": { "$ref": "#/$defs/sha256" }, "symlink_target_sha256": { "$ref": "#/$defs/sha256" }, "deletion_marker": { "const": true }, "submodule_head": { "$ref": "#/$defs/gitCommit" }, "submodule_dirty": { "type": "boolean" } } }
  }
}
