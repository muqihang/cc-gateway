{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "oracle-lab-run-manifest.schema.json",
  "title": "Oracle Lab Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "compatibility_policy",
    "retention_class",
    "redaction_policy",
    "destruction_procedure",
    "phase",
    "entry_kind",
    "approved_tool_head",
    "gateway_compromise_boundary",
    "repositories",
    "contract",
    "governance",
    "policies",
    "dependencies",
    "codegraph",
    "legacy_comparison"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "compatibility_policy": { "const": "fail_closed_exact_schema" },
    "retention_class": { "const": "phase_evidence_permanent" },
    "redaction_policy": { "const": "digests_and_safe_categories_only" },
    "destruction_procedure": { "const": "git_revert_artifact_commit_after_security_approval" },
    "phase": { "enum": ["phase_0_entry", "phase_0_exit"] },
    "entry_kind": { "enum": ["phase_0_entry", "phase_0_exit"] },
    "approved_tool_head": { "$ref": "#/$defs/gitCommit" },
    "gateway_compromise_boundary": { "const": "protected_gateway" },
    "repositories": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cc_gateway", "sub2api"],
      "properties": {
        "cc_gateway": { "$ref": "#/$defs/repository" },
        "sub2api": { "$ref": "#/$defs/repository" }
      }
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path_category", "repository_relative_path_base64url", "sha256"],
      "properties": {
        "path_category": { "const": "sub2api_formal_pool_contract" },
        "repository_relative_path_base64url": { "$ref": "#/$defs/base64url" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "governance": {
      "type": "object", "additionalProperties": false,
      "required": ["requirement_registry", "claim_registry"],
      "properties": { "requirement_registry": { "$ref": "#/$defs/governanceMarker" }, "claim_registry": { "$ref": "#/$defs/governanceMarker" } }
    },
    "policies": {
      "type": "object", "additionalProperties": false, "required": ["network", "sensitivity"],
      "properties": {
        "network": { "type": "object", "additionalProperties": false, "required": ["real_upstream_requests", "local_fixture_only"], "properties": { "real_upstream_requests": { "const": "forbidden" }, "local_fixture_only": { "const": true } } },
        "sensitivity": { "type": "object", "additionalProperties": false, "required": ["persisted_material", "forbidden"], "properties": { "persisted_material": { "const": "safe_categories_and_sha256_digests_only" }, "forbidden": { "type": "array", "prefixItems": [{ "const": "raw_prompt" }, { "const": "raw_body" }, { "const": "credential" }, { "const": "raw_cch" }, { "const": "raw_client_hello" }, { "const": "account_identifier" }, { "const": "proxy_credential" }], "items": false, "minItems": 7, "maxItems": 7 } } }
      }
    },
    "dependencies": { "type": "object", "additionalProperties": false, "required": ["persona_registry", "persona_resolver", "request_policy", "tls_registry", "cch_request_construction", "sidecar_profile", "sidecar_summary", "package_manifest", "package_lock", "sidecar_go_manifest", "sidecar_go_lock", "repository_root_metadata", "tools", "observer_parser_canonicalizer", "runtime_toolchain"], "properties": { "persona_registry": { "$ref": "#/$defs/digestMarker" }, "persona_resolver": { "$ref": "#/$defs/digestMarker" }, "request_policy": { "$ref": "#/$defs/digestMarker" }, "tls_registry": { "$ref": "#/$defs/digestMarker" }, "cch_request_construction": { "$ref": "#/$defs/digestMarker" }, "sidecar_profile": { "$ref": "#/$defs/digestMarker" }, "sidecar_summary": { "$ref": "#/$defs/digestMarker" }, "package_manifest": { "$ref": "#/$defs/digestMarker" }, "package_lock": { "$ref": "#/$defs/digestMarker" }, "sidecar_go_manifest": { "$ref": "#/$defs/digestMarker" }, "sidecar_go_lock": { "$ref": "#/$defs/digestMarker" }, "repository_root_metadata": { "type": "object", "additionalProperties": false, "required": ["cc_gateway_augmentroot", "sub2api_augmentroot"], "properties": { "cc_gateway_augmentroot": { "$ref": "#/$defs/digestMarker" }, "sub2api_augmentroot": { "$ref": "#/$defs/digestMarker" } } }, "tools": { "type": "array", "items": { "$ref": "#/$defs/pathDigest" } }, "observer_parser_canonicalizer": { "type": "array", "items": { "$ref": "#/$defs/pathDigest" } }, "runtime_toolchain": { "type": "object", "additionalProperties": false, "required": ["node", "git", "npm", "go"], "properties": { "node": { "$ref": "#/$defs/sha256" }, "git": { "$ref": "#/$defs/sha256" }, "npm": { "$ref": "#/$defs/sha256" }, "go": { "$ref": "#/$defs/toolDigest" } } } } },
    "codegraph": { "oneOf": [{ "type": "object", "additionalProperties": false, "required": ["status", "index_sha256"], "properties": { "status": { "const": "present" }, "index_sha256": { "$ref": "#/$defs/sha256" } } }, { "type": "object", "additionalProperties": false, "required": ["status", "fallback_reason"], "properties": { "status": { "const": "absent" }, "fallback_reason": { "type": "string", "minLength": 1 } } }] },
    "legacy_comparison": { "type": "object", "additionalProperties": false, "required": ["requirement_id", "version", "authority", "use", "promotion_eligible", "tuple_digests"], "properties": { "requirement_id": { "const": "OL-LEGACY-001" }, "version": { "const": "2.1.197" }, "authority": { "const": "unverified_legacy" }, "use": { "const": "comparison_only" }, "promotion_eligible": { "const": false }, "tuple_digests": { "type": "object", "additionalProperties": false, "required": ["persona", "request_shape", "cch", "tls"], "properties": { "persona": { "$ref": "#/$defs/digestMarker" }, "request_shape": { "$ref": "#/$defs/digestMarker" }, "cch": { "$ref": "#/$defs/digestMarker" }, "tls": { "$ref": "#/$defs/digestMarker" } } } } }
  },
  "allOf": [
    { "if": { "properties": { "phase": { "const": "phase_0_entry" } }, "required": ["phase"] }, "then": { "properties": {
      "entry_kind": { "const": "phase_0_entry" }, "approved_tool_head": { "const": "b9745da781397111a77465a1afb6bbbcb7cfd692" },
      "repositories": { "properties": { "cc_gateway": { "properties": { "head": { "const": "b9745da781397111a77465a1afb6bbbcb7cfd692" }, "branch": { "const": "codex/oracle-phase-0-governance" } } }, "sub2api": { "properties": { "head": { "const": "a0c51e3c674c858fb11b09f21d94d72ec909f554" }, "branch": { "const": "codex/oracle-phase-0-governance" } } } } },
      "contract": { "properties": { "repository_relative_path_base64url": { "const": "YmFja2VuZC9pbnRlcm5hbC9zZXJ2aWNlL3Rlc3RkYXRhL2NjX2dhdGV3YXlfZm9ybWFsX3Bvb2xfY29udHJhY3QvdmVjdG9ycy5qc29u" }, "sha256": { "const": "70c26db06e9135db31d08f097573e3fd55bd9a8894614832eefeecabf6b1a3d1" } } }
    } } },
    { "if": { "properties": { "phase": { "const": "phase_0_exit" } }, "required": ["phase"] }, "then": { "properties": { "entry_kind": { "const": "phase_0_exit" } } } }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "gitCommit": { "type": "string", "pattern": "^[0-9a-f]{40,64}$" },
    "base64url": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_-]+$" },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["head", "branch", "clean", "dirty_digest", "dirty_records", "dirty_record_format", "ignored_exclusion_rules"],
      "properties": {
        "head": { "$ref": "#/$defs/gitCommit" },
        "branch": { "type": "string", "minLength": 1 },
        "clean": { "type": "boolean" },
        "dirty_digest": { "$ref": "#/$defs/sha256" },
        "dirty_record_format": { "const": "u32be_length_prefixed_fields(status,destination,source,object_type,file_mode,content_sha256,symlink_target_sha256,deletion_marker,submodule_head,submodule_dirty); records sorted by destination bytes then source bytes; sha256(records || git_diff_binary_head)" },
        "ignored_exclusion_rules": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["source_category", "rule_sha256"], "properties": { "source_category": { "enum": ["repository_gitignore", "repository_info_exclude", "global_excludes"] }, "source_path_base64url": { "$ref": "#/$defs/base64url" }, "rule_sha256": { "$ref": "#/$defs/sha256" } } } },
        "dirty_records": { "type": "array", "items": { "$ref": "#/$defs/dirtyRecord" } }
      }
    },
    "governanceMarker": { "oneOf": [{ "type": "object", "additionalProperties": false, "required": ["status"], "properties": { "status": { "const": "absent_pre_governance_bootstrap" } } }, { "type": "object", "additionalProperties": false, "required": ["status", "sha256"], "properties": { "status": { "const": "present" }, "sha256": { "$ref": "#/$defs/sha256" } } }] },
    "digestMarker": { "oneOf": [{ "type": "object", "additionalProperties": false, "required": ["status", "sha256"], "properties": { "status": { "const": "present" }, "sha256": { "$ref": "#/$defs/sha256" } } }, { "type": "object", "additionalProperties": false, "required": ["status", "reason"], "properties": { "status": { "const": "absent" }, "reason": { "const": "path_not_present_at_entry" } } }] },
    "pathDigest": { "type": "object", "additionalProperties": false, "required": ["path_base64url", "sha256"], "properties": { "path_base64url": { "$ref": "#/$defs/base64url" }, "sha256": { "$ref": "#/$defs/sha256" } } },
    "toolDigest": { "oneOf": [{ "type": "object", "additionalProperties": false, "required": ["status", "sha256", "provenance"], "properties": { "status": { "const": "present" }, "sha256": { "$ref": "#/$defs/sha256" }, "provenance": { "type": "string", "minLength": 1 } } }, { "type": "object", "additionalProperties": false, "required": ["status", "reason", "required"], "properties": { "status": { "const": "absent" }, "reason": { "const": "tool_not_found" }, "required": { "const": true } } }] },
    "dirtyRecord": { "type": "object", "additionalProperties": false, "required": ["status", "destination_path_base64url", "object_type", "file_mode"], "properties": { "status": { "enum": ["??", "!!", "SM", " M", "M ", "MM", " T", "T ", "TT", "A ", "AM", "AT", " D", "D ", "DT", "R ", "RM", "RT", "C ", "CM", "CT", "DD", "AU", "UD", "UA", "DU", "AA", "UU"] }, "destination_path_base64url": { "$ref": "#/$defs/base64url" }, "source_path_base64url": { "$ref": "#/$defs/base64url" }, "object_type": { "enum": ["regular_file", "symlink", "directory", "submodule", "deleted", "other"] }, "file_mode": { "enum": ["000000", "040000", "100644", "100755", "120000", "160000"] }, "content_sha256": { "$ref": "#/$defs/sha256" }, "symlink_target_sha256": { "$ref": "#/$defs/sha256" }, "deletion_marker": { "const": true }, "submodule_head": { "$ref": "#/$defs/gitCommit" }, "submodule_dirty": { "type": "boolean" } }, "allOf": [
      { "if": { "properties": { "status": { "enum": ["R ", "RM", "RT", "C ", "CM", "CT"] } }, "required": ["status"] }, "then": { "required": ["source_path_base64url"] }, "else": { "not": { "required": ["source_path_base64url"] } } },
      { "if": { "properties": { "object_type": { "const": "regular_file" } }, "required": ["object_type"] }, "then": { "required": ["content_sha256"], "not": { "anyOf": [{ "required": ["symlink_target_sha256"] }, { "required": ["deletion_marker"] }, { "required": ["submodule_head"] }, { "required": ["submodule_dirty"] }] } }, "else": { "not": { "required": ["content_sha256"] } } },
      { "if": { "properties": { "object_type": { "const": "symlink" } }, "required": ["object_type"] }, "then": { "required": ["symlink_target_sha256"] }, "else": { "not": { "required": ["symlink_target_sha256"] } } },
      { "if": { "properties": { "object_type": { "const": "deleted" } }, "required": ["object_type"] }, "then": { "required": ["deletion_marker"] }, "else": { "not": { "required": ["deletion_marker"] } } },
      { "if": { "properties": { "object_type": { "const": "submodule" } }, "required": ["object_type"] }, "then": { "required": ["submodule_head", "submodule_dirty"] }, "else": { "not": { "anyOf": [{ "required": ["submodule_head"] }, { "required": ["submodule_dirty"] }] } } }
    ] }
  }
}
