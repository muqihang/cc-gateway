{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-gateway.invalid/schemas/oracle-lab-governance-amendment-entry-receipt.schema.json",
  "title": "Oracle Lab P0.1 Governance Amendment Entry Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "compatibility_policy",
    "retention_class",
    "redaction_policy",
    "destruction_procedure",
    "receipt_kind",
    "generated_at",
    "reviewed_tool_head",
    "base_main_heads",
    "entry",
    "receipt_path",
    "entry_schema_digest",
    "receipt_schema_digest"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "compatibility_policy": { "const": "phase_0_additive_only_breaking_requires_new_version_and_migration_test" },
    "retention_class": { "const": "phase_evidence_permanent" },
    "redaction_policy": { "const": "digests_and_safe_redacted_excerpts_only" },
    "destruction_procedure": { "const": "git_revert_artifact_commit_after_security_approval" },
    "receipt_kind": { "const": "governance_amendment_entry_receipt" },
    "generated_at": { "$ref": "#/$defs/timestamp" },
    "reviewed_tool_head": { "$ref": "#/$defs/commit" },
    "base_main_heads": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cc_gateway", "sub2api"],
      "properties": {
        "cc_gateway": { "$ref": "#/$defs/commit" },
        "sub2api": { "$ref": "#/$defs/commit" }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "digest"],
      "properties": {
        "path": { "$ref": "#/$defs/relative_path" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "receipt_path": { "$ref": "#/$defs/relative_path" },
    "entry_schema_digest": { "$ref": "#/$defs/digest" },
    "receipt_schema_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "commit": { "type": "string", "pattern": "^[0-9a-f]{40,64}$" },
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "timestamp": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{3})?Z$" },
    "relative_path": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
    }
  }
}
