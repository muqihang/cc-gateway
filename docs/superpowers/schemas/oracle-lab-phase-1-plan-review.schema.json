{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Oracle Lab Phase 1 Plan Review Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_kind",
    "generated_at",
    "plan",
    "reviewer_id",
    "review_round",
    "decision",
    "finding_counts",
    "review_scope"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "review_kind": {"const": "phase_1_plan_review"},
    "generated_at": {"type": "string", "format": "date-time"},
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "digest", "reviewed_commit"],
      "properties": {
        "path": {"const": "docs/superpowers/plans/2026-07-15-claude-code-2.1.207-phase-1-control-plane-boundary-repairs.md"},
        "digest": {"$ref": "#/$defs/digest"},
        "reviewed_commit": {"$ref": "#/$defs/commit"}
      }
    },
    "reviewer_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"},
    "review_round": {"type": "integer", "minimum": 1},
    "decision": {"const": "approved"},
    "finding_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical", "important", "minor"],
      "properties": {
        "critical": {"const": 0},
        "important": {"const": 0},
        "minor": {"type": "integer", "minimum": 0}
      }
    },
    "review_scope": {
      "const": [
        "requirements_and_roadmap_coverage",
        "current_code_anchor_realism",
        "dependency_and_side_effect_ordering",
        "fail_closed_security_boundaries",
        "harness_and_evidence_bindings",
        "commands_tests_and_rollback"
      ]
    }
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "commit": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"}
  }
}
