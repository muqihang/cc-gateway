{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-gateway.local/schemas/oracle-lab-phase3a-artifact-index.schema.json",
  "title": "Oracle Lab Phase 3A artifact index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "evidence_root_id", "previous_index_sha256", "artifacts"],
  "properties": {
    "schema_version": {"const": "oracle-lab-phase3a-artifact-index.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "evidence_root_id": {"type": "string", "pattern": "^[A-Za-z0-9._:-]{1,128}$"},
    "previous_index_sha256": {"anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
    "artifacts": {"type": "array", "items": {"$ref": "#/$defs/artifact"}}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "relativePath": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$", "maxLength": 2048},
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_schema_version", "artifact_id", "run_id", "parent_artifact_ids", "relative_path", "media_type", "byte_size", "sha256", "source_url", "generating_command_digest", "verification_command_digest", "toolchain_digest", "created_at", "scope", "requirement_ids", "owner", "reviewer", "sensitivity", "redaction_transform", "retention_class", "expiry", "destruction_procedure", "disposition", "environment_fingerprint_cell", "parser_name", "parser_version", "parser_agreement", "negative_result", "contradiction_ids", "contradiction_status", "validation_status", "run_digest", "conclusion_digests"],
      "properties": {
        "artifact_schema_version": {"const": "oracle-lab-phase3a-artifact.v1"}, "artifact_id": {"$ref": "#/$defs/id"}, "run_id": {"anyOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]},
        "parent_artifact_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, "relative_path": {"$ref": "#/$defs/relativePath"},
        "media_type": {"type": "string", "minLength": 1}, "byte_size": {"type": "integer", "minimum": 0}, "sha256": {"$ref": "#/$defs/sha256"},
        "source_url": {"anyOf": [{"type": "string", "format": "uri", "pattern": "^https://[^?#]+$"}, {"type": "null"}]},
        "generating_command_digest": {"$ref": "#/$defs/sha256"}, "verification_command_digest": {"$ref": "#/$defs/sha256"}, "toolchain_digest": {"$ref": "#/$defs/sha256"},
        "created_at": {"type": "string", "format": "date-time"}, "scope": {"type": "string", "minLength": 1}, "requirement_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "owner": {"type": "string", "minLength": 1}, "reviewer": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
        "sensitivity": {"enum": ["public-official", "synthetic-raw", "normalized-safe", "quarantine"]}, "redaction_transform": {"type": "string", "minLength": 1},
        "retention_class": {"enum": ["synthetic-raw-14d", "normalized-until-phase3b", "official-artifact-until-acceptance", "quarantine-24h"]}, "expiry": {"type": "string", "format": "date-time"},
        "destruction_procedure": {"type": "string", "minLength": 1}, "disposition": {"enum": ["retain", "cleanup-candidate", "quarantined", "superseded-non-reproducible"]},
        "environment_fingerprint_cell": {"type": "string", "minLength": 1}, "parser_name": {"type": "string", "minLength": 1}, "parser_version": {"type": "string", "minLength": 1},
        "parser_agreement": {"enum": ["single-parser", "agreed", "disagreed", "not-applicable"]}, "negative_result": {"anyOf": [{"type": "string"}, {"type": "null"}]},
        "contradiction_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}, "contradiction_status": {"enum": ["none", "open", "resolved", "accepted-unknown"]},
        "validation_status": {"enum": ["valid", "invalid", "quarantined"]}, "run_digest": {"anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "conclusion_digests": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/sha256"}}
      }
    }
  }
}
