{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "title": "Oracle Lab Post-Integration Command Catalog", "type": "array", "minItems": 8, "maxItems": 8, "additionalProperties": false,
  "items": {"type": "object", "additionalProperties": false, "required": ["id", "schema_version", "group", "owner", "requirement_ids", "repository", "cwd", "argv", "env", "inherit_env", "manifest_binding", "allowed_worktree_delta", "timeout_ms", "expected_exit", "output_policy", "rollback"],
    "properties": {"id": {"type": "string"}, "schema_version": {"const": 1}, "group": {"enum": ["post-integration-green", "post-integration-red"]}, "owner": {"type": "string"}, "requirement_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "repository": {"enum": ["cc-gateway", "sub2api", "egress-tls-sidecar"]}, "cwd": {"type": "string"}, "argv": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "env": {"type": "object", "additionalProperties": {"type": "string"}}, "inherit_env": {"type": "array", "items": {"enum": ["PATH", "HOME", "TMPDIR"]}}, "manifest_binding": {"type": "object", "additionalProperties": false, "required": ["manifest_path", "repository_head_field"], "properties": {"manifest_path": {"const": "${POST_INTEGRATION_MANIFEST}"}, "repository_head_field": {"enum": ["repositories.cc_gateway.head", "repositories.sub2api.head"]}, "contract_digest_field": {"const": "contract.sha256"}}}, "allowed_worktree_delta": {"type": "array", "maxItems": 0}, "timeout_ms": {"type": "integer", "minimum": 1}, "expected_exit": {"enum": [0, "nonzero"]}, "output_policy": {"enum": ["digest_only", "redacted_excerpt"]}, "rollback": {"type": "string"}}
  }
