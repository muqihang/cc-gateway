{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-gateway.invalid/schemas/oracle-lab-governance-amendment-entry.schema.json",
  "title": "Oracle Lab P0.1 Governance Amendment Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "compatibility_policy",
    "retention_class",
    "redaction_policy",
    "destruction_procedure",
    "entry_kind",
    "generated_at",
    "base_main_heads",
    "reviewed_tool_head",
    "repositories",
    "shared_contract",
    "parent_receipts",
    "review_amendment",
    "capture_inputs",
    "codegraph",
    "runtime",
    "disabled_capabilities",
    "p0_1_scope",
    "artifacts"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "compatibility_policy": { "const": "phase_0_additive_only_breaking_requires_new_version_and_migration_test" },
    "retention_class": { "const": "phase_evidence_permanent" },
    "redaction_policy": { "const": "digests_and_safe_redacted_excerpts_only" },
    "destruction_procedure": { "const": "git_revert_artifact_commit_after_security_approval" },
    "entry_kind": { "const": "governance_amendment_entry" },
    "generated_at": { "$ref": "#/$defs/timestamp" },
    "base_main_heads": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cc_gateway", "sub2api"],
      "properties": {
        "cc_gateway": { "$ref": "#/$defs/commit" },
        "sub2api": { "$ref": "#/$defs/commit" }
      }
    },
    "reviewed_tool_head": { "$ref": "#/$defs/commit" },
    "repositories": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cc_gateway", "sub2api"],
      "properties": {
        "cc_gateway": { "$ref": "#/$defs/repository" },
        "sub2api": { "$ref": "#/$defs/repository" }
      }
    },
    "shared_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "path", "digest"],
      "properties": {
        "repository": { "const": "sub2api" },
        "path": { "$ref": "#/$defs/relative_path" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "parent_receipts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase_zero", "post_integration_v2"],
      "properties": {
        "phase_zero": { "$ref": "#/$defs/path_digest" },
        "post_integration_v2": { "$ref": "#/$defs/path_digest" }
      }
    },
    "review_amendment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_digest"],
      "properties": { "source_digest": { "$ref": "#/$defs/digest" } }
    },
    "capture_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capture_tool", "entry_schema", "receipt_schema"],
      "properties": {
        "capture_tool": { "$ref": "#/$defs/path_digest" },
        "entry_schema": { "$ref": "#/$defs/path_digest" },
        "receipt_schema": { "$ref": "#/$defs/path_digest" }
      }
    },
    "codegraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cc_gateway", "sub2api"],
      "properties": {
        "cc_gateway": { "$ref": "#/$defs/codegraph" },
        "sub2api": { "$ref": "#/$defs/codegraph" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "npm", "git", "go", "codegraph", "network_policy"],
      "properties": {
        "node": { "$ref": "#/$defs/digest" },
        "npm": { "$ref": "#/$defs/digest" },
        "git": { "$ref": "#/$defs/digest" },
        "go": { "$ref": "#/$defs/digest" },
        "codegraph": { "$ref": "#/$defs/digest" },
        "network_policy": { "$ref": "#/$defs/digest" }
      }
    },
    "disabled_capabilities": {
      "const": [
        "real_upstream_access",
        "real_credentials",
        "provider_internal_authority",
        "profile_promotion",
        "production_deployment",
        "real_canary",
        "direct_egress_trust",
        "unverified_pinned_wire_claims",
        "unsupported_negative_capabilities",
        "expired_or_missing_negative_capabilities",
        "unrestricted_capture",
        "external_network_requests"
      ]
    },
    "p0_1_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["release", "work_package", "requirement_ids", "in_scope", "out_of_scope"],
      "properties": {
        "release": { "const": "P0.1" },
        "work_package": { "const": "WP-R0" },
        "requirement_ids": {
          "const": ["HA-P0-004", "HA-P0-007", "RA-P0-001"]
        },
        "in_scope": {
          "const": [
            "adopt_and_correct_review_amendment",
            "overlay_prior_specifications",
            "preserve_seven_phases_with_mandatory_3b_3_5",
            "wp_r0_through_wp_r9_traceability_umbrellas",
            "requirement_registry_v2_and_v1_migration",
            "register_18_ra_requirements_as_deferred",
            "claim_matrix_prohibited_conclusions",
            "ra_current_observation_ledger",
            "bounded_ra_current_009_four_local_test_yaml_repairs",
            "two_joint_tests_in_successor_cross_repository_green_inventory",
            "successor_p0_1_evidence_chain",
            "exact_p1_entry_conditions"
          ]
        },
        "out_of_scope": {
          "const": [
            "b1_through_b3_implementation",
            "b4_through_b6_implementation",
            "shared_readiness_handshake_or_contract_redesign",
            "profile_compiler_profile_or_evidence_factory_implementation",
            "account_policy_replay_response_scheduler_or_replica_runtime_work",
            "large_scale_proxy_refactor",
            "production_credentials_external_network_canary_or_promotion",
            "historical_phase_zero_or_post_integration_evidence_mutation"
          ]
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entry_path", "receipt_path"],
      "properties": {
        "entry_path": { "$ref": "#/$defs/relative_path" },
        "receipt_path": { "$ref": "#/$defs/relative_path" }
      }
    }
  },
  "$defs": {
    "commit": { "type": "string", "pattern": "^[0-9a-f]{40,64}$" },
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "timestamp": { "type": "string", "pattern": "^(?:[0-9]{4}-(?:(?:01|03|05|07|08|10|12)-(?:0[1-9]|[12][0-9]|3[01])|(?:04|06|09|11)-(?:0[1-9]|[12][0-9]|30)|02-(?:0[1-9]|1[0-9]|2[0-8]))|(?:(?:[0-9]{2}(?:0[48]|[2468][048]|[13579][26]))|(?:(?:0[48]|[2468][048]|[13579][26])00)|0000)-02-29)T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{3})?Z$" },
    "relative_path": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
    },
    "path_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "digest"],
      "properties": {
        "path": { "$ref": "#/$defs/relative_path" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "remote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "ref", "commit", "url_digest"],
      "properties": {
        "name": { "const": "muqihang" },
        "ref": { "const": "refs/remotes/muqihang/main" },
        "commit": { "$ref": "#/$defs/commit" },
        "url_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["head", "base_main_head", "branch", "descends_from_base_main", "clean", "dirty_digest", "user_fork_main"],
      "properties": {
        "head": { "$ref": "#/$defs/commit" },
        "base_main_head": { "$ref": "#/$defs/commit" },
        "branch": { "type": "string", "minLength": 1 },
        "descends_from_base_main": { "const": true },
        "clean": { "const": true },
        "dirty_digest": { "$ref": "#/$defs/digest" },
        "user_fork_main": { "$ref": "#/$defs/remote" }
      }
    },
    "codegraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "up_to_date", "index_digest", "file_count", "node_count", "edge_count"],
      "properties": {
        "version": { "const": "1.1.6" },
        "up_to_date": { "const": true },
        "index_digest": { "$ref": "#/$defs/digest" },
        "file_count": { "type": "integer", "minimum": 1 },
        "node_count": { "type": "integer", "minimum": 1 },
        "edge_count": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
