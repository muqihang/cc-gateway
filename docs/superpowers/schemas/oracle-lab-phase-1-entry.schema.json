{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Oracle Lab Phase 1 Planning Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "entry_kind",
    "generated_at",
    "expires_at",
    "repositories",
    "parent_receipts",
    "shared_contract",
    "codegraph",
    "runtime",
    "phase_scope",
    "gate_results",
    "planning_entry_conditions",
    "implementation_entry",
    "disabled_capabilities"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "entry_kind": {"const": "phase_1_planning_entry"},
    "generated_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "repositories": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cc_gateway", "sub2api"],
      "properties": {
        "cc_gateway": {"$ref": "#/$defs/repository"},
        "sub2api": {"$ref": "#/$defs/repository"}
      }
    },
    "parent_receipts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase_zero", "post_integration_v2", "p0_1_successor"],
      "properties": {
        "phase_zero": {"$ref": "#/$defs/path_digest"},
        "post_integration_v2": {"$ref": "#/$defs/path_digest"},
        "p0_1_successor": {"$ref": "#/$defs/path_digest"}
      }
    },
    "shared_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "path", "digest"],
      "properties": {
        "repository": {"const": "sub2api"},
        "path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
        "digest": {"$ref": "#/$defs/digest"}
      }
    },
    "codegraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cc_gateway", "sub2api"],
      "properties": {
        "cc_gateway": {"$ref": "#/$defs/codegraph_index"},
        "sub2api": {"$ref": "#/$defs/codegraph_index"}
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "npm", "go", "git", "codegraph"],
      "properties": {
        "node": {"type": "string", "minLength": 1},
        "npm": {"type": "string", "minLength": 1},
        "go": {"type": "string", "minLength": 1},
        "git": {"type": "string", "minLength": 1},
        "codegraph": {"type": "string", "minLength": 1}
      }
    },
    "phase_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement_ids", "work_package_slices", "in_scope", "out_of_scope"],
      "properties": {
        "requirement_ids": {
          "const": ["AV-B1-001", "AV-B2-001", "AV-B3-001", "RA-P0-008"]
        },
        "work_package_slices": {"const": ["WP-R8:phase_1_loopback_remote_tls_guard"]},
        "in_scope": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "out_of_scope": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "gate_results": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed_at", "green_count", "expected_fail_count", "records"],
      "properties": {
        "observed_at": {"type": "string", "format": "date-time"},
        "green_count": {"const": 7},
        "expected_fail_count": {"const": 3},
        "records": {
          "type": "array",
          "minItems": 10,
          "maxItems": 10,
          "items": {"$ref": "#/$defs/gate_record"}
        }
      }
    },
    "planning_entry_conditions": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["condition", "status"],
        "properties": {
          "condition": {"type": "string", "minLength": 1},
          "status": {"const": "pass"}
        }
      }
    },
    "implementation_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "blocking_conditions"],
      "properties": {
        "status": {"const": "blocked"},
        "blocking_conditions": {
          "const": ["fresh_phase_1_plan", "independent_plan_approval"]
        }
      }
    },
    "disabled_capabilities": {
      "const": [
        "real_upstream_access",
        "real_credentials",
        "provider_internal_authority",
        "profile_promotion",
        "production_deployment",
        "real_canary",
        "direct_egress_trust",
        "unverified_pinned_wire_claims",
        "unsupported_negative_capabilities",
        "expired_or_missing_negative_capabilities",
        "unrestricted_capture",
        "external_network_requests"
      ]
    }
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "commit": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
    "path_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "digest"],
      "properties": {
        "path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
        "digest": {"$ref": "#/$defs/digest"}
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["head", "remote_main_head", "branch", "tracking_ref", "clean", "dirty_digest"],
      "properties": {
        "head": {"$ref": "#/$defs/commit"},
        "remote_main_head": {"$ref": "#/$defs/commit"},
        "branch": {"const": "codex/oracle-phase-1-plan"},
        "tracking_ref": {"const": "refs/remotes/muqihang/main"},
        "clean": {"const": true},
        "dirty_digest": {"const": "sha256:e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"}
      }
    },
    "codegraph_index": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "up_to_date", "file_count", "node_count", "edge_count", "index_digest"],
      "properties": {
        "version": {"const": "1.1.6"},
        "up_to_date": {"const": true},
        "file_count": {"type": "integer", "minimum": 1},
        "node_count": {"type": "integer", "minimum": 1},
        "edge_count": {"type": "integer", "minimum": 1},
        "index_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "gate_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command_id", "repository", "status", "exit_code", "scope"],
      "properties": {
        "command_id": {"type": "string", "minLength": 1},
        "repository": {"enum": ["cc-gateway", "sub2api", "egress-tls-sidecar"]},
        "status": {"enum": ["pass", "expected_fail"]},
        "exit_code": {"type": "integer", "minimum": 0},
        "scope": {"type": "string", "minLength": 1}
      }
    }
  }
}
