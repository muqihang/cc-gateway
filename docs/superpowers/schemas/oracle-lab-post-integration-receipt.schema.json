{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "title": "Oracle Lab Post-Integration Receipt", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "receipt_kind", "generated_at", "artifact_commit", "reviewed_tool_head", "entry_manifest_digest", "command_results_digest", "context_digest", "handoff_digest", "phase_zero_exit_receipt_digest", "artifact_digests", "repositories", "disabled_capabilities", "next_phase_gates", "retention_policy", "redaction_policy", "destruction_procedure"],
  "properties": {
    "schema_version": {"const": 1}, "receipt_kind": {"const": "post_integration_receipt"}, "generated_at": {"type": "string", "format": "date-time"}, "artifact_commit": {"$ref": "#/$defs/commit"}, "reviewed_tool_head": {"$ref": "#/$defs/commit"},
    "entry_manifest_digest": {"$ref": "#/$defs/digest"}, "command_results_digest": {"$ref": "#/$defs/digest"}, "context_digest": {"$ref": "#/$defs/digest"}, "handoff_digest": {"$ref": "#/$defs/digest"}, "phase_zero_exit_receipt_digest": {"$ref": "#/$defs/digest"},
    "artifact_digests": {"type": "object", "additionalProperties": false, "required": ["entry_manifest", "command_results", "context", "handoff"], "properties": {"entry_manifest": {"$ref": "#/$defs/artifact"}, "command_results": {"$ref": "#/$defs/artifact"}, "context": {"$ref": "#/$defs/artifact"}, "handoff": {"$ref": "#/$defs/artifact"}}},
    "repositories": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["name", "commit", "remote_ref"], "properties": {"name": {"enum": ["cc_gateway", "sub2api"]}, "commit": {"$ref": "#/$defs/commit"}, "remote_ref": {"const": "refs/remotes/muqihang/main"}}}},
    "disabled_capabilities": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}, "next_phase_gates": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "retention_policy": {"const": "phase_evidence_permanent"}, "redaction_policy": {"const": "digests_and_safe_redacted_excerpts_only"}, "destruction_procedure": {"const": "git_revert_artifact_commit_after_security_approval"}
  },
  "$defs": {"digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "commit": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"}, "artifact": {"type": "object", "additionalProperties": false, "required": ["path", "digest"], "properties": {"path": {"type": "string"}, "digest": {"$ref": "#/$defs/digest"}}}}
}
