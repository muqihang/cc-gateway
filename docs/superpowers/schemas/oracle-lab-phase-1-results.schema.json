            "head": {
              "type": "string",
              "pattern": "^[0-9a-f]{40,64}$"
            },
            "root_identity_digest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            },
            "clean_status_digest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
