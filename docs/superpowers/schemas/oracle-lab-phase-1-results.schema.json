        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "stage": {
          "enum": [
            "implementation_entry",
            "implementation",
            "feature_capture",
            "post_integration"
          ]
        },
        "artifact_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40,64}$"
        }
      }
    },
    "roots": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "controller",
        "cc_gateway",
        "sub2api"
      ],
      "properties": {
        "controller": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "stage",
            "head",
            "root_identity_digest",
            "same_as_tested_cc_root",
            "preexisting_delta_paths",
            "declared_output_paths"
          ],
          "properties": {
            "stage": {
              "enum": [
                "feature-candidate",
                "post-integration"
              ]
            },
            "head": {
              "type": "string",
              "pattern": "^[0-9a-f]{40,64}$"
            },
            "root_identity_digest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            },
            "same_as_tested_cc_root": {
              "type": "boolean"
            },
            "preexisting_delta_paths": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
              }
            },
            "declared_output_paths": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
              }
            }
          }
        },
        "cc_gateway": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "head",
            "root_identity_digest",
            "clean_status_digest"
          ],
          "properties": {
            "head": {
              "type": "string",
              "pattern": "^[0-9a-f]{40,64}$"
            },
            "root_identity_digest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            },
            "clean_status_digest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          }
        },
        "sub2api": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "head",
            "root_identity_digest",
            "clean_status_digest"
          ],
          "properties": {
            "head": {
              "type": "string",
              "pattern": "^[0-9a-f]{40,64}$"
            },
            "root_identity_digest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            },
            "clean_status_digest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          }
        }
      }
    },
    "sandbox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter",
        "executable_digest",
        "policy_digest",
        "loopback_ipv4",
        "loopback_ipv6",
        "non_loopback",
        "policy_bypass_detected"
      ],
      "properties": {
        "adapter": {
          "const": "macos_sandbox_exec_loopback_v1"
        },
        "executable_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "policy_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "loopback_ipv4": {
          "const": "pass"
        },
        "loopback_ipv6": {
          "const": "pass"
        },
        "non_loopback": {
          "const": "denied_by_policy"
        },
        "policy_bypass_detected": {
          "const": false
        }
      }
    },
    "ignored_state_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["controller", "cc_gateway", "sub2api"],
      "properties": {
        "controller": {"$ref": "#/$defs/ignored_state"},
        "cc_gateway": {"$ref": "#/$defs/ignored_state"},
        "sub2api": {"$ref": "#/$defs/ignored_state"}
      }
    },
    "ignored_transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "policy_digest", "before", "after"],
      "properties": {
        "policy": {"enum": ["none", "cc_build_dist_v1", "sub_frontend_build_v1", "sub2api_joint_safe_deliverable_v1", "controller_alias_cc_gateway_v1"]},
        "policy_digest": {"$ref": "#/$defs/digest"},
        "before": {"$ref": "#/$defs/ignored_state"},
        "after": {"$ref": "#/$defs/ignored_state"}
      }
    },
    "parser_lifecycle": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["parser", "tap_version_count", "terminal_plan_count", "declared_test_count", "observed_test_count", "pass_count", "fail_count", "cancelled_count", "skipped_count", "todo_count", "unexplained_stderr_line_count"],
          "properties": {
            "parser": {"const": "node_test_tap_v1"},
            "tap_version_count": {"type": "integer", "minimum": 0},
            "terminal_plan_count": {"type": "integer", "minimum": 0},
            "declared_test_count": {"type": "integer", "minimum": 0},
            "observed_test_count": {"type": "integer", "minimum": 0},
            "pass_count": {"type": "integer", "minimum": 0},
            "fail_count": {"type": "integer", "minimum": 0},
            "cancelled_count": {"type": "integer", "minimum": 0},
            "skipped_count": {"type": "integer", "minimum": 0},
            "todo_count": {"type": "integer", "minimum": 0},
            "unexplained_stderr_line_count": {"type": "integer", "minimum": 0}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["parser", "packages", "unexplained_stderr_line_count", "malformed_or_unparsed_event_count"],
          "properties": {
            "parser": {"const": "go_test_json_leaf_v1"},
            "packages": {
              "type": "array", "minItems": 2, "maxItems": 2,
              "items": {
                "type": "object", "additionalProperties": false,
                "required": ["package_suffix", "start_count", "run_test_count", "terminal_test_count", "pass_test_count", "fail_test_count", "skip_test_count", "package_fail_terminal_count", "post_terminal_event_count"],
                "properties": {
                  "package_suffix": {"enum": ["internal/control", "internal/server"]},
                  "start_count": {"type": "integer", "minimum": 0},
                  "run_test_count": {"type": "integer", "minimum": 0},
                  "terminal_test_count": {"type": "integer", "minimum": 0},
                  "pass_test_count": {"type": "integer", "minimum": 0},
                  "fail_test_count": {"type": "integer", "minimum": 0},
                  "skip_test_count": {"type": "integer", "minimum": 0},
                  "package_fail_terminal_count": {"type": "integer", "minimum": 0},
                  "post_terminal_event_count": {"type": "integer", "minimum": 0}
                }
              }
            },
            "unexplained_stderr_line_count": {"type": "integer", "minimum": 0},
            "malformed_or_unparsed_event_count": {"type": "integer", "minimum": 0}
          }
        }
      ]
    },
    "npm_cache_preparation": {
      "type": "object", "additionalProperties": false,
      "required": ["policy", "source_before_digest", "source_after_digest", "command_before_digest", "command_after_digest", "entry_count", "regular_file_count", "regular_file_bytes", "install_result_digest"],
      "properties": {
        "policy": {"const": "os_account_cow_cache_v1"},
        "source_before_digest": {"$ref": "#/$defs/digest"}, "source_after_digest": {"$ref": "#/$defs/digest"},
        "command_before_digest": {"$ref": "#/$defs/digest"}, "command_after_digest": {"$ref": "#/$defs/digest"},
        "entry_count": {"type": "integer", "minimum": 1}, "regular_file_count": {"type": "integer", "minimum": 1},
        "regular_file_bytes": {"type": "integer", "minimum": 1}, "install_result_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "external_dependency_binding": {
      "type": "object", "additionalProperties": false,
      "required": ["algorithm", "repository", "preparation", "node_binary_digest", "npm_binary_digest", "go_binary_digest", "npm_cache_preparation", "node_dependency_manifests", "go_module_manifests", "binding_digest"],
      "properties": {
        "algorithm": {"const": "phase1_external_dependency_content_v1"},
        "repository": {"enum": ["cc_gateway", "sub2api"]},
        "preparation": {"const": "npm_ci_offline_authenticated_cache_and_go_mod_verify_v2"},
        "node_binary_digest": {"$ref": "#/$defs/digest"},
        "npm_binary_digest": {"$ref": "#/$defs/digest"},
        "go_binary_digest": {"$ref": "#/$defs/digest"},
        "npm_cache_preparation": {"$ref": "#/$defs/npm_cache_preparation"},
        "node_dependency_manifests": {
          "type": "array", "minItems": 1, "maxItems": 1,
          "prefixItems": [{
            "type": "object", "additionalProperties": false,
            "required": ["repository_relative_root", "package_json_digest", "package_lock_digest", "entry_count", "content_digest"],
            "properties": {
              "repository_relative_root": {"enum": [".", "frontend"]},
              "package_json_digest": {"$ref": "#/$defs/digest"},
              "package_lock_digest": {"$ref": "#/$defs/digest"},
              "entry_count": {"type": "integer", "minimum": 0},
              "content_digest": {"$ref": "#/$defs/digest"}
            }
          }], "items": false
        },
        "go_module_manifests": {
          "type": "array", "minItems": 1, "maxItems": 1,
          "prefixItems": [{
            "type": "object", "additionalProperties": false,
            "required": ["repository_relative_root", "go_mod_digest", "go_sum_digest", "module_count", "module_manifest_digest", "module_content_digest", "go_mod_verify_digest"],
            "properties": {
              "repository_relative_root": {"enum": ["sidecar/egress-tls-sidecar", "backend"]},
              "go_mod_digest": {"$ref": "#/$defs/digest"},
              "go_sum_digest": {"$ref": "#/$defs/digest"},
              "module_count": {"type": "integer", "minimum": 0},
              "module_manifest_digest": {"$ref": "#/$defs/digest"},
              "module_content_digest": {"$ref": "#/$defs/digest"},
              "go_mod_verify_digest": {"$ref": "#/$defs/digest"}
            }
          }], "items": false
        },
        "binding_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "external_dependency_set": {
      "type": "object", "additionalProperties": false,
      "required": ["cc_gateway", "sub2api"],
      "properties": {
        "cc_gateway": {"$ref": "#/$defs/external_dependency_binding"},
        "sub2api": {"$ref": "#/$defs/external_dependency_binding"}
      }
    },
    "external_dependency_transition": {
      "type": "object", "additionalProperties": false,
      "required": ["before", "after", "ephemeral_build_cache_token"],
      "properties": {
        "before": {"$ref": "#/$defs/external_dependency_set"},
        "after": {"$ref": "#/$defs/external_dependency_set"},
        "ephemeral_build_cache_token": {"const": "command_scoped_empty_mkdtemp_v1"}
      }
    },
    "command_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command_id", "repository", "repository_commit", "exit_code", "status", "stdout_digest", "stderr_digest", "failure_parser", "parser_lifecycle", "failure_event_count", "failure_event_names", "failure_count", "failure_names", "observed_failure_families", "unclassified_failure_names", "sandbox_policy_digest", "network_policy_violations", "unsafe_output_detected", "ignored_state_transitions", "external_dependency_transition", "result_digest"],
      "properties": {
        "command_id": {"type": "string", "minLength": 1},
        "repository": {"enum": ["cc-gateway", "sub2api", "egress-tls-sidecar"]},
        "repository_commit": {"$ref": "#/$defs/commit"},
        "exit_code": {"type": "integer"},
        "status": {"enum": ["pass", "expected_fail"]},
        "stdout_digest": {"$ref": "#/$defs/digest"},
        "stderr_digest": {"$ref": "#/$defs/digest"},
        "failure_parser": {"type": ["string", "null"], "enum": [null, "node_test_tap_v1", "go_test_json_leaf_v1"]},
        "parser_lifecycle": {"$ref": "#/$defs/parser_lifecycle"},
        "failure_event_count": {"type": "integer", "minimum": 0},
        "failure_event_names": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "failure_count": {"type": "integer", "minimum": 0},
        "failure_names": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "observed_failure_families": {"type": "array", "items": {"enum": ["B4", "B5", "B6", "TestPhase0B5", "TestPhase0B6"]}, "uniqueItems": true},
        "unclassified_failure_names": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "sandbox_policy_digest": {"$ref": "#/$defs/digest"},
        "network_policy_violations": {"const": 0},
        "unsafe_output_detected": {"const": false},
        "ignored_state_transitions": {
          "type": "object", "additionalProperties": false,
          "required": ["controller", "cc_gateway", "sub2api"],
          "properties": {
            "controller": {"$ref": "#/$defs/ignored_transition"},
            "cc_gateway": {"$ref": "#/$defs/ignored_transition"},
            "sub2api": {"$ref": "#/$defs/ignored_transition"}
          }
        },
        "external_dependency_transition": {"$ref": "#/$defs/external_dependency_transition"},
        "result_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "disabled": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "uniqueItems": true,
      "items": {
        "enum": [
          "real_upstream_access",
          "real_credentials",
          "provider_internal_authority",
          "profile_promotion",
          "production_deployment",
          "real_canary",
          "direct_egress_trust",
          "unverified_pinned_wire_claims",
          "unsupported_negative_capabilities",
          "expired_or_missing_negative_capabilities",
          "unrestricted_capture",
          "external_network_requests"
        ]
      }
    }
  }
}
