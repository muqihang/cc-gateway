{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "title": "Oracle Lab Post-Integration Handoff", "compatibility_policy": "phase_0_additive_only_breaking_requires_new_version_and_migration_test", "retention_class": "phase_evidence_permanent", "redaction_policy": "digests_and_safe_redacted_excerpts_only", "destruction_procedure": "git_revert_artifact_commit_after_security_approval", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "compatibility_policy", "retention_class", "redaction_policy", "destruction_procedure", "handoff_kind", "generated_at", "expires_at", "entry_manifest", "command_results", "context", "phase_zero_exit", "reviewed_tool_head", "repositories", "disabled_capabilities", "next_phase_gates"],
  "properties": {
    "schema_version": {"const": 1}, "compatibility_policy": {"const": "phase_0_additive_only_breaking_requires_new_version_and_migration_test"}, "retention_class": {"const": "phase_evidence_permanent"}, "redaction_policy": {"const": "digests_and_safe_redacted_excerpts_only"}, "destruction_procedure": {"const": "git_revert_artifact_commit_after_security_approval"}, "handoff_kind": {"const": "post_integration_handoff"}, "generated_at": {"type": "string", "format": "date-time"}, "expires_at": {"type": "string", "format": "date-time"},
    "entry_manifest": {"$ref": "#/$defs/artifact"},
    "command_results": {"type": "object", "additionalProperties": false, "required": ["path", "digest", "result_set_digest", "record_count"], "properties": {"path": {"type": "string"}, "digest": {"$ref": "#/$defs/digest"}, "result_set_digest": {"$ref": "#/$defs/digest"}, "record_count": {"const": 8}}},
    "context": {"type": "object", "additionalProperties": false, "required": ["path", "digest", "manifest_digest", "command_results_digest"], "properties": {"path": {"type": "string"}, "digest": {"$ref": "#/$defs/digest"}, "manifest_digest": {"$ref": "#/$defs/digest"}, "command_results_digest": {"$ref": "#/$defs/digest"}}},
    "phase_zero_exit": {"type": "object", "additionalProperties": false, "required": ["receipt_path", "receipt_digest", "handoff_commit"], "properties": {"receipt_path": {"type": "string"}, "receipt_digest": {"$ref": "#/$defs/digest"}, "handoff_commit": {"$ref": "#/$defs/commit"}}},
    "reviewed_tool_head": {"$ref": "#/$defs/commit"},
    "repositories": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["name", "commit", "remote_name", "remote_ref", "remote_commit", "remote_url_digest"], "properties": {"name": {"enum": ["cc_gateway", "sub2api"]}, "commit": {"$ref": "#/$defs/commit"}, "remote_name": {"const": "muqihang"}, "remote_ref": {"const": "refs/remotes/muqihang/main"}, "remote_commit": {"$ref": "#/$defs/commit"}, "remote_url_digest": {"$ref": "#/$defs/digest"}}}},
    "disabled_capabilities": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}, "next_phase_gates": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
  },
  "$defs": {"digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "commit": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"}, "artifact": {"type": "object", "additionalProperties": false, "required": ["path", "digest"], "properties": {"path": {"type": "string"}, "digest": {"$ref": "#/$defs/digest"}}}}
}
