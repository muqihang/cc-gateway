{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-gateway.local/schemas/oracle-lab-phase3a-exit.schema.json",
  "title": "Oracle Lab Phase 3A blocked exit report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "generated_at", "artifact_index_sha256", "conclusion_digest", "sections", "missing_gates"],
  "properties": {
    "schema_version": {"const": "oracle-lab-phase3a-exit.v1"},
    "status": {"const": "BLOCKED"},
    "generated_at": {"type": "string", "format": "date-time"},
    "artifact_index_sha256": {"$ref": "#/$defs/sha256"},
    "conclusion_digest": {"$ref": "#/$defs/sha256"},
    "missing_gates": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 512}},
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository_state", "artifact_identity", "toolchain_capabilities", "static_analysis", "coverage", "protocol_runtime_summaries", "perturbation_source_agreement", "evidence_health", "conclusions", "p2_mapping", "evidence_hygiene", "reproduction", "phase3b_inputs", "safety_confirmation"],
      "properties": {
        "repository_state": {"$ref": "#/$defs/section"},
        "artifact_identity": {"$ref": "#/$defs/section"},
        "toolchain_capabilities": {"$ref": "#/$defs/section"},
        "static_analysis": {"$ref": "#/$defs/section"},
        "coverage": {"$ref": "#/$defs/section"},
        "protocol_runtime_summaries": {"$ref": "#/$defs/section"},
        "perturbation_source_agreement": {"$ref": "#/$defs/section"},
        "evidence_health": {"$ref": "#/$defs/section"},
        "conclusions": {"$ref": "#/$defs/section"},
        "p2_mapping": {"$ref": "#/$defs/section"},
        "evidence_hygiene": {"$ref": "#/$defs/section"},
        "reproduction": {"$ref": "#/$defs/section"},
        "phase3b_inputs": {"$ref": "#/$defs/section"},
        "safety_confirmation": {"$ref": "#/$defs/section"}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "section": {"type": "object", "additionalProperties": false, "required": ["status", "details"], "properties": {"status": {"enum": ["COMPLETE", "PARTIAL", "BLOCKED"]}, "details": {"anyOf": [{"type": "object"}, {"type": "array"}]}}}
  }
}
