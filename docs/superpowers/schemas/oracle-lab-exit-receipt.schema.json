{"$schema":"https://json-schema.org/draft/2020-12/schema","title":"Oracle Lab Exit Receipt","compatibility_policy":"phase_0_additive_only_breaking_requires_new_version_and_migration_test","retention_class":"phase_evidence_permanent","redaction_policy":"digests_and_safe_redacted_excerpts_only","destruction_procedure":"git_revert_artifact_commit_after_security_approval","type":"object","additionalProperties":false,"required":["schema_version","generated_at","baseline_digest","handoff_digest","handoff_commit","artifact_digests","repository_heads","retention_class","redaction_policy","destruction_procedure"],"properties":{"schema_version":{"const":1},"generated_at":{"type":"string","format":"date-time"},"baseline_digest":{"$ref":"#/$defs/digest"},"handoff_digest":{"$ref":"#/$defs/digest"},"handoff_commit":{"type":"string","pattern":"^[0-9a-f]{40,64}$"},"artifact_digests":{"type":"object","minProperties":6,"maxProperties":6,"propertyNames":{"type":"string","minLength":1},"additionalProperties":{"$ref":"#/$defs/digest"}},"repository_heads":{"type":"object","additionalProperties":false,"required":["cc_gateway","sub2api"],"properties":{"cc_gateway":{"type":"string","pattern":"^[0-9a-f]{40,64}$"},"sub2api":{"type":"string","pattern":"^[0-9a-f]{40,64}$"}}},"retention_class":{"const":"phase_evidence_permanent"},"redaction_policy":{"const":"digests_and_safe_redacted_excerpts_only"},"destruction_procedure":{"const":"git_revert_artifact_commit_after_security_approval"}},"$defs":{"digest":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"}}}
