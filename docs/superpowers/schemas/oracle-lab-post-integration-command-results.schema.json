{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "title": "Oracle Lab Post-Integration Command Results", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "generated_at", "expires_at", "catalog_digest", "manifest_digest", "records", "result_set_digest"],
  "properties": {"schema_version": {"const": 1}, "generated_at": {"type": "string", "format": "date-time"}, "expires_at": {"type": "string", "format": "date-time"}, "catalog_digest": {"$ref": "#/$defs/digest"}, "manifest_digest": {"$ref": "#/$defs/digest"}, "records": {"type": "array", "minItems": 8, "maxItems": 8, "items": {"$ref": "#/$defs/record"}}, "result_set_digest": {"$ref": "#/$defs/digest"}},
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "record": {"type": "object", "additionalProperties": false, "required": ["command_id", "repository", "repository_commit", "manifest_digest", "environment_digest", "exit_code", "expected_exit", "status", "duration_ms", "output_digest", "result_digest"], "properties": {"command_id": {"enum": ["cc-build", "cc-test", "cc-cross-repo-baseline", "sidecar-test", "sub2api-test", "cc-b4-b6-red", "sidecar-b4-b6-red", "sub2api-b1-b3-red"]}, "repository": {"enum": ["cc-gateway", "sub2api", "egress-tls-sidecar"]}, "repository_commit": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"}, "contract_digest": {"$ref": "#/$defs/digest"}, "manifest_digest": {"$ref": "#/$defs/digest"}, "environment_digest": {"$ref": "#/$defs/digest"}, "exit_code": {"type": "integer", "minimum": 0}, "expected_exit": {"enum": [0, "nonzero"]}, "status": {"enum": ["pass", "expected_fail", "unexpected_fail", "unexpected_pass"]}, "duration_ms": {"type": "integer", "minimum": 0}, "output_digest": {"$ref": "#/$defs/digest"}, "output_excerpt": {"type": "string", "maxLength": 2048}, "result_digest": {"$ref": "#/$defs/digest"}}}
  }
}
