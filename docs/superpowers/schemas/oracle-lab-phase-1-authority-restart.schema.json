{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Oracle Lab Phase 1 Authority Restart",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "repair_id", "repaired_authority", "repositories", "projected_tree_policy"],
  "properties": {
    "schema_version": {"const": 1},
    "repair_id": {"const": "authority-repair-0001"},
    "repaired_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plan", "plan_review", "execution_context"],
      "properties": {
        "plan": {"$ref": "#/$defs/authority_artifact"},
        "plan_review": {"$ref": "#/$defs/authority_artifact"},
        "execution_context": {"$ref": "#/$defs/authority_artifact"}
      }
    },
    "repositories": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cc_gateway", "sub2api"],
      "properties": {
        "cc_gateway": {"$ref": "#/$defs/cc_repository"},
        "sub2api": {"$ref": "#/$defs/repository"}
      }
    },
    "projected_tree_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority_repair_paths", "historical_authority_paths"],
      "properties": {
        "authority_repair_paths": {"$ref": "#/$defs/path_set"},
        "historical_authority_paths": {"$ref": "#/$defs/path_set"}
      }
    }
  },
  "$defs": {
    "commit": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*[\\u0000-\\u001f]).+$"},
    "path_set": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/path"}
    },
    "authority_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "digest", "commit"],
      "properties": {
        "path": {"$ref": "#/$defs/path"},
        "digest": {"$ref": "#/$defs/digest"},
        "commit": {"$ref": "#/$defs/commit"}
      }
    },
    "changed_path": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "old_mode", "new_mode", "old_path", "new_path"],
      "properties": {
        "status": {"type": "string", "pattern": "^(?:A|D|M|T|R[0-9]{1,3}|C[0-9]{1,3})$"},
        "old_mode": {"oneOf": [{"type": "null"}, {"type": "string", "pattern": "^[0-7]{6}$"}]},
        "new_mode": {"oneOf": [{"type": "null"}, {"type": "string", "pattern": "^[0-7]{6}$"}]},
        "old_path": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/path"}]},
        "new_path": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/path"}]}
      }
    },
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_commit", "source_parent", "replacement_commit", "replacement_parent", "stable_patch_id", "changed_paths"],
      "properties": {
        "source_commit": {"$ref": "#/$defs/commit"},
        "source_parent": {"$ref": "#/$defs/commit"},
        "replacement_commit": {"$ref": "#/$defs/commit"},
        "replacement_parent": {"$ref": "#/$defs/commit"},
        "stable_patch_id": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "changed_paths": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/changed_path"}
        }
      }
    },
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branch", "head", "remote_name", "remote_ref", "remote_url_digest"],
      "properties": {
        "branch": {"type": "string", "minLength": 1},
        "head": {"$ref": "#/$defs/commit"},
        "remote_name": {"const": "muqihang"},
        "remote_ref": {"const": "refs/remotes/muqihang/main"},
        "remote_url_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "replacement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branch", "remote_main_head", "authorized_base_head", "replay_head", "remote_name", "remote_ref", "remote_url_digest"],
      "properties": {
        "branch": {"type": "string", "minLength": 1},
        "remote_main_head": {"$ref": "#/$defs/commit"},
        "authorized_base_head": {"$ref": "#/$defs/commit"},
        "replay_head": {"$ref": "#/$defs/commit"},
        "remote_name": {"const": "muqihang"},
        "remote_ref": {"const": "refs/remotes/muqihang/main"},
        "remote_url_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["superseded", "replacement", "replay_mappings", "projected_tree_digest"],
      "properties": {
        "superseded": {"$ref": "#/$defs/endpoint"},
        "replacement": {"$ref": "#/$defs/replacement"},
        "replay_mappings": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/mapping"}
        },
        "projected_tree_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "cc_repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["superseded", "replacement", "replay_mappings", "projected_tree_digest", "quarantine_checkpoint"],
      "properties": {
        "superseded": {"$ref": "#/$defs/endpoint"},
        "replacement": {"$ref": "#/$defs/replacement"},
        "replay_mappings": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/mapping"}},
        "projected_tree_digest": {"$ref": "#/$defs/digest"},
        "quarantine_checkpoint": {
          "type": "object",
          "additionalProperties": false,
          "required": ["commit", "parent", "stable_patch_id", "changed_paths"],
          "properties": {
            "commit": {"$ref": "#/$defs/commit"},
            "parent": {"$ref": "#/$defs/commit"},
            "stable_patch_id": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
            "changed_paths": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/changed_path"}}
          }
        }
      }
    }
  }
}
